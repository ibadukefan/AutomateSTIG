{
  "stig_id": "Samsung_Android_14_STIG",
  "platform": "generic",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-262000", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep passwordQuality", "pattern": "passwordQuality=\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality policy must be enforced" },
    { "vuln_id": "V-262001", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep passwordMinimumLength", "pattern": "passwordMinimumLength=[6-9]|passwordMinimumLength=[1-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Minimum password length must be 6 or more characters" },
    { "vuln_id": "V-262002", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep maximumFailedPasswordsForWipe", "pattern": "maximumFailedPasswordsForWipe=([1-9]|10)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Device must wipe after maximum failed password attempts" },
    { "vuln_id": "V-262003", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep maximumTimeToLock", "pattern": "maximumTimeToLock=[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Maximum screen lock timeout must be configured" },
    { "vuln_id": "V-262004", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep encryptionRequested", "pattern": "encryptionRequested=true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Device encryption must be enabled" },
    { "vuln_id": "V-262005", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep cameraDisabled", "pattern": "cameraDisabled", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Camera policy must be configured" },
    { "vuln_id": "V-262006", "platform": "generic", "check": { "type": "command", "command": "settings get global bluetooth_on", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Bluetooth must be disabled by default" },
    { "vuln_id": "V-262007", "platform": "generic", "check": { "type": "command", "command": "settings get global install_non_market_apps", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Installation from unknown sources must be disabled" },
    { "vuln_id": "V-262008", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep keyguardDisabledFeatures", "pattern": "keyguardDisabledFeatures=\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Keyguard disabled features must be configured" },
    { "vuln_id": "V-262009", "platform": "generic", "check": { "type": "command", "command": "settings get global development_settings_enabled", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Developer options must be disabled" },
    { "vuln_id": "V-262010", "platform": "generic", "check": { "type": "command", "command": "settings get global adb_enabled", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "USB debugging must be disabled" },
    { "vuln_id": "V-262011", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep passwordHistoryLength", "pattern": "passwordHistoryLength=[5-9]|passwordHistoryLength=[1-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password history must prevent reuse of at least 5 passwords" },
    { "vuln_id": "V-262012", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep passwordExpirationTimeout", "pattern": "passwordExpirationTimeout=[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password expiration timeout must be configured" },
    { "vuln_id": "V-262013", "platform": "generic", "check": { "type": "command", "command": "settings get secure location_mode", "pattern": "^[0-3]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Location services mode must be configured" },
    { "vuln_id": "V-262014", "platform": "generic", "check": { "type": "command", "command": "dumpsys device_policy | grep screenCaptureDisabled", "pattern": "screenCaptureDisabled=true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Screen capture must be disabled by policy" }
  ]
}
