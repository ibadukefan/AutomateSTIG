{
  "stig_id": "Citrix_VAD_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-259101",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Security", "value_name": "MinimumTLSVersion" },
      "expected": { "type": "equals", "value": "1.2" },
      "description": "Citrix VAD must enforce TLS 1.2 as minimum version"
    },
    {
      "vuln_id": "V-259102",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Security", "value_name": "SSLCipherSuite" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "Citrix VAD must configure an approved SSL cipher suite"
    },
    {
      "vuln_id": "V-259103",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Security", "value_name": "SSLEnabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Citrix VAD must enable SSL for ICA connections"
    },
    {
      "vuln_id": "V-259104",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Citrix\\Ica\\Session", "value_name": "MaxSessionIdleTime" },
      "expected": { "type": "matches", "pattern": "\\d+" },
      "description": "Citrix VAD must configure session idle timeout"
    },
    {
      "vuln_id": "V-259105",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Citrix\\Ica\\Session", "value_name": "MaxDisconnectionTime" },
      "expected": { "type": "matches", "pattern": "\\d+" },
      "description": "Citrix VAD must configure disconnection timeout"
    },
    {
      "vuln_id": "V-259106",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Citrix\\Ica\\Session", "value_name": "MaxConnectionTime" },
      "expected": { "type": "matches", "pattern": "\\d+" },
      "description": "Citrix VAD must configure maximum connection time"
    },
    {
      "vuln_id": "V-259107",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Logging", "value_name": "AuditEnabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Citrix VAD must enable audit logging"
    },
    {
      "vuln_id": "V-259108",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Logging", "value_name": "LogLevel" },
      "expected": { "type": "matches", "pattern": "\\d+" },
      "description": "Citrix VAD audit log level must be configured"
    },
    {
      "vuln_id": "V-259109",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Security", "value_name": "EnableSecureICA" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Citrix VAD must enable SecureICA encryption for sessions"
    },
    {
      "vuln_id": "V-259110",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Security", "value_name": "EncryptionLevel" },
      "expected": { "type": "equals", "value": "RC5 (128 bit)" },
      "description": "Citrix VAD must use at least 128-bit encryption for ICA sessions"
    },
    {
      "vuln_id": "V-259111",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\StoreFront", "value_name": "RequireHTTPS" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Citrix StoreFront must require HTTPS"
    },
    {
      "vuln_id": "V-259112",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Graphics", "value_name": "AllowClipboardRedirection" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Citrix VAD must disable clipboard redirection when not required"
    },
    {
      "vuln_id": "V-259113",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\FileRedirection", "value_name": "AllowDriveRedirection" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Citrix VAD must disable client drive redirection when not required"
    },
    {
      "vuln_id": "V-259114",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\ICA\\Printing", "value_name": "AllowPrinterRedirection" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Citrix VAD must disable client printer redirection when not required"
    },
    {
      "vuln_id": "V-259115",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Citrix\\Authentication", "value_name": "MaxFailedAttempts" },
      "expected": { "type": "less_or_equal", "value": 5 },
      "description": "Citrix VAD must lock out accounts after 5 or fewer failed login attempts"
    }
  ]
}
