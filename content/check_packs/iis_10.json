{
  "stig_id": "IIS_10_Server_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-218785",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.2\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS must use TLS 1.2 (server-side enabled)"
    },
    {
      "vuln_id": "V-218786",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\SSL 2.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SSL 2.0 must be disabled on the IIS server"
    },
    {
      "vuln_id": "V-218787",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\SSL 3.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SSL 3.0 must be disabled on the IIS server"
    },
    {
      "vuln_id": "V-218788",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.0 must be disabled on the IIS server"
    },
    {
      "vuln_id": "V-218789",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.1\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.1 must be disabled on the IIS server"
    },
    {
      "vuln_id": "V-218790",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.2\\Server", "value_name": "DisabledByDefault" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.2 must not be disabled by default on the IIS server"
    },
    {
      "vuln_id": "V-218795",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp", "value_name": "EnableLogging" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS logging must be enabled"
    },
    {
      "vuln_id": "V-218796",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileDate" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include date"
    },
    {
      "vuln_id": "V-218797",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileTime" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include time"
    },
    {
      "vuln_id": "V-218798",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileClientIp" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include client IP"
    },
    {
      "vuln_id": "V-218799",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileUserName" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include user name"
    },
    {
      "vuln_id": "V-218800",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileMethod" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include request method"
    },
    {
      "vuln_id": "V-218801",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileUriQuery" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include URI query"
    },
    {
      "vuln_id": "V-218802",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileHttpStatus" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS log files must include HTTP status"
    },
    {
      "vuln_id": "V-218810",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "MaxFieldLength" },
      "expected": { "type": "less_or_equal", "value": 65534 },
      "description": "IIS MaxFieldLength must be configured to limit header size"
    },
    {
      "vuln_id": "V-218811",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "MaxRequestBytes" },
      "expected": { "type": "less_or_equal", "value": 16777216 },
      "description": "IIS MaxRequestBytes must be configured to limit request size"
    },
    {
      "vuln_id": "V-218812",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "UriEnableCache" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS URI cache must be enabled"
    },
    {
      "vuln_id": "V-218815",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "EnableNonUTF8" },
      "expected": { "type": "equals", "value": 0 },
      "description": "IIS must not allow non-UTF8 URLs"
    },
    {
      "vuln_id": "V-218816",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "FavorUTF8" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS must favor UTF-8 encoding"
    },
    {
      "vuln_id": "V-218820",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\CurrentVersion\\Internet Settings", "value_name": "PreventCodecDownload" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS must prevent codec downloads"
    },
    {
      "vuln_id": "V-218825",
      "platform": "windows",
      "check": { "type": "service", "name": "W3SVC", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "World Wide Web Publishing Service must be running"
    },
    {
      "vuln_id": "V-218826",
      "platform": "windows",
      "check": { "type": "service", "name": "WAS", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "Windows Process Activation Service must be running"
    },
    {
      "vuln_id": "V-218830",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "value_name": "LegalNoticeText" },
      "expected": { "type": "matches", "pattern": ".{10,}" },
      "description": "IIS server must display legal notice text before logon"
    },
    {
      "vuln_id": "V-218831",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp", "value_name": "MajorVersion" },
      "expected": { "type": "greater_or_equal", "value": 10 },
      "description": "IIS must be version 10 or later"
    },
    {
      "vuln_id": "V-218835",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "DisableServerHeader" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS must suppress the server version in HTTP headers"
    }
  ]
}
