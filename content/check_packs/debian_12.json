{
  "stig_id": "Debian_12_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-261200", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Debian 12 SSH must not allow direct root login" },
    { "vuln_id": "V-261201", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must not allow empty passwords" },
    { "vuln_id": "V-261202", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveInterval must be set" },
    { "vuln_id": "V-261203", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveCountMax\\s+[01]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveCountMax must be 1 or less" },
    { "vuln_id": "V-261204", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must display a login banner" },
    { "vuln_id": "V-261205", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH X11 forwarding must be disabled" },
    { "vuln_id": "V-261206", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "UsePAM\\s+yes", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use PAM" },
    { "vuln_id": "V-261210", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.ip_forward" }, "expected": { "type": "equals", "value": "0" }, "description": "IP forwarding must be disabled" },
    { "vuln_id": "V-261211", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Source-routed packets must not be accepted" },
    { "vuln_id": "V-261212", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "ICMP redirects must not be accepted" },
    { "vuln_id": "V-261213", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.send_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "System must not send ICMP redirects" },
    { "vuln_id": "V-261214", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.tcp_syncookies" }, "expected": { "type": "equals", "value": "1" }, "description": "TCP SYN cookies must be enabled" },
    { "vuln_id": "V-261215", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.randomize_va_space" }, "expected": { "type": "equals", "value": "2" }, "description": "ASLR must be fully enabled" },
    { "vuln_id": "V-261216", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.dmesg_restrict" }, "expected": { "type": "equals", "value": "1" }, "description": "Kernel message buffer must be restricted" },
    { "vuln_id": "V-261217", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv6.conf.all.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "IPv6 source routing must be disabled" },
    { "vuln_id": "V-261220", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/shadow", "owner": "root", "group": "shadow", "mode": "0640" }, "expected": { "type": "is_true" }, "description": "/etc/shadow must be mode 0640, owned by root:shadow" },
    { "vuln_id": "V-261221", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/passwd", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/passwd must be mode 0644 and owned by root" },
    { "vuln_id": "V-261222", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/group", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/group must be mode 0644 and owned by root" },
    { "vuln_id": "V-261223", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/ssh/sshd_config", "owner": "root", "group": null, "mode": "0600" }, "expected": { "type": "is_true" }, "description": "sshd_config must be mode 0600 and owned by root" },
    { "vuln_id": "V-261230", "platform": "linux", "check": { "type": "package", "name": "aide", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "AIDE must be installed for file integrity checking" },
    { "vuln_id": "V-261231", "platform": "linux", "check": { "type": "package", "name": "auditd", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "Audit package must be installed" },
    { "vuln_id": "V-261232", "platform": "linux", "check": { "type": "package", "name": "apparmor", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "AppArmor must be installed" },
    { "vuln_id": "V-261233", "platform": "linux", "check": { "type": "package", "name": "telnetd", "should_be_installed": false }, "expected": { "type": "is_true" }, "description": "Telnet server must not be installed" },
    { "vuln_id": "V-261240", "platform": "linux", "check": { "type": "service", "name": "apparmor", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "AppArmor must be active" },
    { "vuln_id": "V-261241", "platform": "linux", "check": { "type": "service", "name": "auditd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Audit daemon must be running" }
  ]
}
