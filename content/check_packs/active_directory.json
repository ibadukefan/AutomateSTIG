{
  "stig_id": "Active_Directory_Domain_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-243469", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\NTDS\\Parameters", "value_name": "LDAPServerIntegrity" }, "expected": { "type": "equals", "value": 2 }, "description": "LDAP server signing must be required" },
    { "vuln_id": "V-243470", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\NTDS\\Parameters", "value_name": "LdapEnforceChannelBinding" }, "expected": { "type": "equals", "value": 2 }, "description": "LDAP channel binding must be set to Always" },
    { "vuln_id": "V-243471", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\Netlogon\\Parameters", "value_name": "RequireSignOrSeal" }, "expected": { "type": "equals", "value": 1 }, "description": "Domain controller Netlogon must require signing or sealing" },
    { "vuln_id": "V-243472", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\Netlogon\\Parameters", "value_name": "SealSecureChannel" }, "expected": { "type": "equals", "value": 1 }, "description": "Domain controller secure channel traffic must be encrypted" },
    { "vuln_id": "V-243473", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\Netlogon\\Parameters", "value_name": "SignSecureChannel" }, "expected": { "type": "equals", "value": 1 }, "description": "Domain controller secure channel traffic must be signed" },
    { "vuln_id": "V-243474", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\Netlogon\\Parameters", "value_name": "RequireStrongKey" }, "expected": { "type": "equals", "value": 1 }, "description": "Domain controller must require strong session keys" },
    { "vuln_id": "V-243475", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "value_name": "LmCompatibilityLevel" }, "expected": { "type": "equals", "value": 5 }, "description": "LAN Manager authentication must be NTLMv2 with NTLMv1 refused" },
    { "vuln_id": "V-243476", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "value_name": "NoLMHash" }, "expected": { "type": "equals", "value": 1 }, "description": "LM hash values must not be stored on domain controllers" },
