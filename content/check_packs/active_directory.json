    { "vuln_id": "V-243480", "platform": "windows", "check": { "type": "security_policy", "section": "Kerberos Policy", "key": "MaxClockSkew" }, "expected": { "type": "less_or_equal", "value": 5 }, "description": "Kerberos maximum tolerance for clock synchronization must be 5 minutes or less" },
    { "vuln_id": "V-243481", "platform": "windows", "check": { "type": "security_policy", "section": "Kerberos Policy", "key": "TicketValidateClient" }, "expected": { "type": "equals", "value": "1" }, "description": "Kerberos client ticket validation must be enforced" },
    { "vuln_id": "V-243482", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\NTDS\\Parameters", "value_name": "DSHeuristics" }, "expected": { "type": "equals", "value": "" }, "description": "DS Heuristics must not be configured to allow anonymous access" },
    { "vuln_id": "V-243483", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "value_name": "RestrictAnonymousSAM" }, "expected": { "type": "equals", "value": 1 }, "description": "Anonymous SAM enumeration must not be allowed on domain controllers" },
    { "vuln_id": "V-243484", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "value_name": "RestrictAnonymous" }, "expected": { "type": "equals", "value": 1 }, "description": "Anonymous enumeration of shares must be restricted" },
    { "vuln_id": "V-243485", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "value_name": "EveryoneIncludesAnonymous" }, "expected": { "type": "equals", "value": 0 }, "description": "Everyone permissions must not apply to anonymous users" },
    { "vuln_id": "V-243486", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanServer\\Parameters", "value_name": "RequireSecuritySignature" }, "expected": { "type": "equals", "value": 1 }, "description": "SMB server signing must be required on domain controllers" },
    { "vuln_id": "V-243487", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\LanmanWorkstation\\Parameters", "value_name": "RequireSecuritySignature" }, "expected": { "type": "equals", "value": 1 }, "description": "SMB client signing must be required on domain controllers" },
    { "vuln_id": "V-243488", "platform": "windows", "check": { "type": "security_policy", "section": "System Access", "key": "MinimumPasswordLength" }, "expected": { "type": "greater_or_equal", "value": 14 }, "description": "Domain password minimum length must be at least 14 characters" },
    { "vuln_id": "V-243489", "platform": "windows", "check": { "type": "security_policy", "section": "System Access", "key": "PasswordComplexity" }, "expected": { "type": "equals", "value": "1" }, "description": "Domain passwords must meet complexity requirements" },
    { "vuln_id": "V-243490", "platform": "windows", "check": { "type": "security_policy", "section": "System Access", "key": "PasswordHistorySize" }, "expected": { "type": "greater_or_equal", "value": 24 }, "description": "Domain password history must remember 24 passwords" },
    { "vuln_id": "V-243491", "platform": "windows", "check": { "type": "security_policy", "section": "System Access", "key": "LockoutBadCount" }, "expected": { "type": "less_or_equal", "value": 3 }, "description": "Domain account lockout threshold must be 3 or fewer" },
    { "vuln_id": "V-243492", "platform": "windows", "check": { "type": "security_policy", "section": "System Access", "key": "ResetLockoutCount" }, "expected": { "type": "greater_or_equal", "value": 15 }, "description": "Domain account lockout counter reset must be at least 15 minutes" },
    { "vuln_id": "V-243493", "platform": "windows", "check": { "type": "security_policy", "section": "System Access", "key": "LockoutDuration" }, "expected": { "type": "greater_or_equal", "value": 15 }, "description": "Domain account lockout duration must be at least 15 minutes" },
    { "vuln_id": "V-243494", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\NTDS\\Parameters", "value_name": "Tombstone Lifetime" }, "expected": { "type": "greater_or_equal", "value": 180 }, "description": "AD tombstone lifetime must be at least 180 days" },
    { "vuln_id": "V-243495", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa\\MSV1_0", "value_name": "NTLMMinServerSec" }, "expected": { "type": "equals", "value": 537395200 }, "description": "NTLM minimum server security must require NTLMv2 and 128-bit encryption" },
    { "vuln_id": "V-243496", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa\\MSV1_0", "value_name": "NTLMMinClientSec" }, "expected": { "type": "equals", "value": 537395200 }, "description": "NTLM minimum client security must require NTLMv2 and 128-bit encryption" },
    { "vuln_id": "V-243497", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "value_name": "LegalNoticeText" }, "expected": { "type": "matches", "pattern": ".{10,}" }, "description": "Domain controllers must display a legal notice before logon" },
    { "vuln_id": "V-243498", "platform": "windows", "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\NTDS\\Diagnostics", "value_name": "16 LDAP Interface Events" }, "expected": { "type": "greater_or_equal", "value": 2 }, "description": "AD diagnostic logging for LDAP interface events must be enabled" }
  ]
