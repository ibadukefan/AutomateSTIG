      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/elasticsearch/elasticsearch.yml", "pattern": "network\\.host:\\s*\\S+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Elasticsearch must bind to a specific network host"
    },
    {
      "vuln_id": "V-272112",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/elasticsearch/elasticsearch.yml", "pattern": "http\\.port:\\s*\\d+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Elasticsearch HTTP port must be explicitly configured"
