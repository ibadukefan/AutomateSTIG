    },
    {
      "vuln_id": "V-272115",
      "platform": "linux",
      "check": { "type": "file_permission", "path": "/etc/elasticsearch/elasticsearch.yml", "owner": "elasticsearch", "group": null, "mode": "0600" },
      "expected": { "type": "is_true" },
      "description": "Elasticsearch configuration file must be mode 0600 and owned by elasticsearch user"
