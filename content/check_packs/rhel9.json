{
  "stig_id": "RHEL_9_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-257777",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "SSH must not allow direct root login"
    },
    {
      "vuln_id": "V-257778",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "SSH must not allow empty passwords"
    },
    {
      "vuln_id": "V-257779",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Protocol\\s+2", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "SSH must use protocol version 2"
    },
    {
      "vuln_id": "V-257780",
