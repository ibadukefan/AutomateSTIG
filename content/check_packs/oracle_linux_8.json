{
  "stig_id": "Oracle_Linux_8_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-248500", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Oracle Linux 8 SSH must not allow direct root login" },
    { "vuln_id": "V-248501", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must not allow empty passwords" },
    { "vuln_id": "V-248502", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveInterval must be set" },
    { "vuln_id": "V-248503", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveCountMax\\s+[01]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveCountMax must be 1 or less" },
    { "vuln_id": "V-248504", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "MaxAuthTries\\s+[1-4]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH MaxAuthTries must be 4 or fewer" },
    { "vuln_id": "V-248505", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must display a login banner" },
    { "vuln_id": "V-248506", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH X11 forwarding must be disabled" },
    { "vuln_id": "V-248507", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Ciphers\\s+.*aes256-ctr", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use FIPS 140-2 compliant ciphers" },
    { "vuln_id": "V-248508", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "MACs\\s+.*hmac-sha2-256", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use FIPS 140-2 compliant MACs" },
    { "vuln_id": "V-248509", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "GSSAPIAuthentication\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH GSSAPI authentication must be disabled" },
    { "vuln_id": "V-248510", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.ip_forward" }, "expected": { "type": "equals", "value": "0" }, "description": "IP forwarding must be disabled" },
    { "vuln_id": "V-248511", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Source-routed packets must not be accepted" },
    { "vuln_id": "V-248512", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.default.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Default source route acceptance must be disabled" },
    { "vuln_id": "V-248513", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "ICMP redirects must not be accepted" },
    { "vuln_id": "V-248514", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.send_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "System must not send ICMP redirects" },
    { "vuln_id": "V-248515", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.tcp_syncookies" }, "expected": { "type": "equals", "value": "1" }, "description": "TCP SYN cookies must be enabled" },
    { "vuln_id": "V-248516", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.randomize_va_space" }, "expected": { "type": "equals", "value": "2" }, "description": "ASLR must be fully enabled" },
    { "vuln_id": "V-248517", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.dmesg_restrict" }, "expected": { "type": "equals", "value": "1" }, "description": "Kernel message buffer must be restricted" },
    { "vuln_id": "V-248520", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/shadow", "owner": "root", "group": null, "mode": "0000" }, "expected": { "type": "is_true" }, "description": "/etc/shadow must be mode 0000 and owned by root" },
    { "vuln_id": "V-248521", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/passwd", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/passwd must be mode 0644 and owned by root" },
    { "vuln_id": "V-248522", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/group", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/group must be mode 0644 and owned by root" },
    { "vuln_id": "V-248523", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/gshadow", "owner": "root", "group": null, "mode": "0000" }, "expected": { "type": "is_true" }, "description": "/etc/gshadow must be mode 0000 and owned by root" },
    { "vuln_id": "V-248524", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/ssh/sshd_config", "owner": "root", "group": null, "mode": "0600" }, "expected": { "type": "is_true" }, "description": "sshd_config must be mode 0600 and owned by root" },
    { "vuln_id": "V-248530", "platform": "linux", "check": { "type": "package", "name": "aide", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "AIDE must be installed for file integrity checking" },
    { "vuln_id": "V-248531", "platform": "linux", "check": { "type": "package", "name": "audit", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "Audit package must be installed" },
    { "vuln_id": "V-248532", "platform": "linux", "check": { "type": "package", "name": "firewalld", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "Firewalld must be installed" },
    { "vuln_id": "V-248533", "platform": "linux", "check": { "type": "package", "name": "telnet-server", "should_be_installed": false }, "expected": { "type": "is_true" }, "description": "Telnet server must not be installed" },
    { "vuln_id": "V-248540", "platform": "linux", "check": { "type": "service", "name": "auditd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Audit daemon must be running" },
    { "vuln_id": "V-248541", "platform": "linux", "check": { "type": "service", "name": "firewalld", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Firewall must be active" },
    { "vuln_id": "V-248542", "platform": "linux", "check": { "type": "file_content", "path": "/etc/selinux/config", "pattern": "SELINUX=enforcing", "is_regex": false }, "expected": { "type": "is_true" }, "description": "SELinux must be set to enforcing mode" }
  ]
}
