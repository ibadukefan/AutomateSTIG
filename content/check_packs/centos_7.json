{
  "stig_id": "CentOS_7_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-204500", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "CentOS 7 SSH must not allow direct root login" },
    { "vuln_id": "V-204501", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must not allow empty passwords" },
    { "vuln_id": "V-204502", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+600", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveInterval must be set to 600 seconds or less" },
    { "vuln_id": "V-204503", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveCountMax\\s+0", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveCountMax must be set to 0" },
    { "vuln_id": "V-204504", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must display a DoD-approved banner" },
    { "vuln_id": "V-204505", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Protocol\\s+2", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use protocol version 2" },
    { "vuln_id": "V-204506", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH X11 forwarding must be disabled" },
    { "vuln_id": "V-204507", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Ciphers\\s+.*aes256-ctr", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use FIPS 140-2 compliant ciphers" },
    { "vuln_id": "V-204510", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.ip_forward" }, "expected": { "type": "equals", "value": "0" }, "description": "IP forwarding must be disabled unless acting as a router" },
    { "vuln_id": "V-204511", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Source-routed packets must not be accepted" },
    { "vuln_id": "V-204512", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.default.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Default source route acceptance must be disabled" },
    { "vuln_id": "V-204513", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "ICMP redirects must not be accepted" },
    { "vuln_id": "V-204514", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.default.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "Default ICMP redirect acceptance must be disabled" },
    { "vuln_id": "V-204515", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.send_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "System must not send ICMP redirects" },
    { "vuln_id": "V-204516", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.icmp_echo_ignore_broadcasts" }, "expected": { "type": "equals", "value": "1" }, "description": "System must ignore ICMP broadcast echo requests" },
    { "vuln_id": "V-204517", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.rp_filter" }, "expected": { "type": "equals", "value": "1" }, "description": "Reverse path filtering must be enabled" },
    { "vuln_id": "V-204518", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.tcp_syncookies" }, "expected": { "type": "equals", "value": "1" }, "description": "TCP SYN cookies must be enabled" },
    { "vuln_id": "V-204519", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.randomize_va_space" }, "expected": { "type": "equals", "value": "2" }, "description": "ASLR must be fully enabled" },
    { "vuln_id": "V-204520", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/shadow", "owner": "root", "group": null, "mode": "0000" }, "expected": { "type": "is_true" }, "description": "/etc/shadow must be mode 0000 and owned by root" },
    { "vuln_id": "V-204521", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/passwd", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/passwd must be mode 0644 and owned by root" },
    { "vuln_id": "V-204522", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/group", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/group must be mode 0644 and owned by root" },
    { "vuln_id": "V-204523", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/gshadow", "owner": "root", "group": null, "mode": "0000" }, "expected": { "type": "is_true" }, "description": "/etc/gshadow must be mode 0000 and owned by root" },
    { "vuln_id": "V-204524", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/ssh/sshd_config", "owner": "root", "group": null, "mode": "0600" }, "expected": { "type": "is_true" }, "description": "sshd_config must be mode 0600 and owned by root" },
    { "vuln_id": "V-204525", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/audit/auditd.conf", "owner": "root", "group": null, "mode": "0640" }, "expected": { "type": "is_true" }, "description": "auditd.conf must be mode 0640 and owned by root" },
    { "vuln_id": "V-204530", "platform": "linux", "check": { "type": "package", "name": "aide", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "AIDE must be installed for file integrity checking" },
    { "vuln_id": "V-204531", "platform": "linux", "check": { "type": "package", "name": "audit", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "Audit package must be installed" },
    { "vuln_id": "V-204532", "platform": "linux", "check": { "type": "package", "name": "telnet-server", "should_be_installed": false }, "expected": { "type": "is_true" }, "description": "Telnet server must not be installed" },
    { "vuln_id": "V-204533", "platform": "linux", "check": { "type": "package", "name": "rsh-server", "should_be_installed": false }, "expected": { "type": "is_true" }, "description": "RSH server must not be installed" },
    { "vuln_id": "V-204540", "platform": "linux", "check": { "type": "service", "name": "auditd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Audit daemon must be running" },
    { "vuln_id": "V-204541", "platform": "linux", "check": { "type": "service", "name": "firewalld", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Firewalld service must be running" },
    { "vuln_id": "V-204542", "platform": "linux", "check": { "type": "file_content", "path": "/etc/selinux/config", "pattern": "SELINUX=enforcing", "is_regex": false }, "expected": { "type": "is_true" }, "description": "SELinux must be set to enforcing mode" },
    { "vuln_id": "V-204543", "platform": "linux", "check": { "type": "file_content", "path": "/proc/sys/crypto/fips_enabled", "pattern": "1", "is_regex": false }, "expected": { "type": "is_true" }, "description": "FIPS mode must be enabled" },
    { "vuln_id": "V-204550", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MIN_LEN\\s+1[5-9]|PASS_MIN_LEN\\s+[2-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Minimum password length must be 15 or more characters" },
    { "vuln_id": "V-204551", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MAX_DAYS\\s+60", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Maximum password age must be 60 days or less" },
    { "vuln_id": "V-204552", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MIN_DAYS\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Minimum password age must be at least 1 day" },
    { "vuln_id": "V-204553", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "ENCRYPT_METHOD\\s+SHA512", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Passwords must be hashed with SHA-512" },
    { "vuln_id": "V-204554", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "minlen\\s*=\\s*1[5-9]|minlen\\s*=\\s*[2-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require minimum length of 15" },
    { "vuln_id": "V-204555", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "dcredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one digit" },
    { "vuln_id": "V-204556", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "ucredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one uppercase character" },
    { "vuln_id": "V-204557", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "ocredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one special character" }
  ]
