{
  "stig_id": "RHEL_7_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-204392", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "RHEL 7 SSH must not allow direct root login" },
    { "vuln_id": "V-204393", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must not allow empty passwords" },
    { "vuln_id": "V-204394", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+600", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveInterval must be set to 600 seconds or less" },
    { "vuln_id": "V-204395", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveCountMax\\s+0", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveCountMax must be set to 0" },
    { "vuln_id": "V-204396", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must display a DoD-approved banner before login" },
    { "vuln_id": "V-204397", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Protocol\\s+2", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use protocol version 2" },
    { "vuln_id": "V-204398", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH X11 forwarding must be disabled" },
    { "vuln_id": "V-204399", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Ciphers\\s+.*aes256-ctr", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use FIPS 140-2 compliant ciphers" },
    { "vuln_id": "V-204400", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.ip_forward" }, "expected": { "type": "equals", "value": "0" }, "description": "IP forwarding must be disabled unless acting as a router" },
    { "vuln_id": "V-204401", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Source-routed packets must not be accepted" },
    { "vuln_id": "V-204402", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.default.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Default source route acceptance must be disabled" },
    { "vuln_id": "V-204403", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "ICMP redirects must not be accepted" },
    { "vuln_id": "V-204404", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.default.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "Default ICMP redirect acceptance must be disabled" },
    { "vuln_id": "V-204405", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.send_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "System must not send ICMP redirects" },
    { "vuln_id": "V-204406", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.default.send_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "Default ICMP redirect sending must be disabled" },
    { "vuln_id": "V-204407", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.icmp_echo_ignore_broadcasts" }, "expected": { "type": "equals", "value": "1" }, "description": "System must ignore ICMP broadcast echo requests" },
    { "vuln_id": "V-204408", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.rp_filter" }, "expected": { "type": "equals", "value": "1" }, "description": "Reverse path filtering must be enabled" },
    { "vuln_id": "V-204409", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.tcp_syncookies" }, "expected": { "type": "equals", "value": "1" }, "description": "TCP SYN cookies must be enabled" },
    { "vuln_id": "V-204410", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.randomize_va_space" }, "expected": { "type": "equals", "value": "2" }, "description": "ASLR must be fully enabled" },
    { "vuln_id": "V-204411", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/shadow", "owner": "root", "group": null, "mode": "0000" }, "expected": { "type": "is_true" }, "description": "/etc/shadow must be mode 0000 and owned by root" },
    { "vuln_id": "V-204412", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/passwd", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/passwd must be mode 0644 and owned by root" },
    { "vuln_id": "V-204413", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/group", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/group must be mode 0644 and owned by root" },
    { "vuln_id": "V-204414", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/gshadow", "owner": "root", "group": null, "mode": "0000" }, "expected": { "type": "is_true" }, "description": "/etc/gshadow must be mode 0000 and owned by root" },
    { "vuln_id": "V-204415", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/ssh/sshd_config", "owner": "root", "group": null, "mode": "0600" }, "expected": { "type": "is_true" }, "description": "sshd_config must be mode 0600 and owned by root" },
    { "vuln_id": "V-204416", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/audit/auditd.conf", "owner": "root", "group": null, "mode": "0640" }, "expected": { "type": "is_true" }, "description": "auditd.conf must be mode 0640 and owned by root" },
    { "vuln_id": "V-204420", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MIN_LEN\\s+1[5-9]|PASS_MIN_LEN\\s+[2-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Minimum password length must be 15 or more characters" },
    { "vuln_id": "V-204421", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MAX_DAYS\\s+60", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Maximum password age must be 60 days or less" },
    { "vuln_id": "V-204422", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MIN_DAYS\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Minimum password age must be at least 1 day" },
    { "vuln_id": "V-204423", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "ENCRYPT_METHOD\\s+SHA512", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Passwords must be hashed with SHA-512" },
    { "vuln_id": "V-204424", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "minlen\\s*=\\s*1[5-9]|minlen\\s*=\\s*[2-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require minimum length of 15" },
    { "vuln_id": "V-204425", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "dcredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one digit" },
    { "vuln_id": "V-204426", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "ucredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one uppercase character" },
    { "vuln_id": "V-204427", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "lcredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one lowercase character" },
    { "vuln_id": "V-204428", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "ocredit\\s*=\\s*-1", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require at least one special character" },
    { "vuln_id": "V-204430", "platform": "linux", "check": { "type": "package", "name": "aide", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "AIDE must be installed for file integrity checking" },
    { "vuln_id": "V-204431", "platform": "linux", "check": { "type": "package", "name": "audit", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "Audit package must be installed" },
    { "vuln_id": "V-204432", "platform": "linux", "check": { "type": "service", "name": "firewalld", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Firewalld service must be running" },
    { "vuln_id": "V-204433", "platform": "linux", "check": { "type": "service", "name": "auditd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Audit daemon must be running" },
    { "vuln_id": "V-204434", "platform": "linux", "check": { "type": "file_content", "path": "/proc/sys/crypto/fips_enabled", "pattern": "1", "is_regex": false }, "expected": { "type": "is_true" }, "description": "FIPS mode must be enabled" },
    { "vuln_id": "V-204435", "platform": "linux", "check": { "type": "file_content", "path": "/etc/selinux/config", "pattern": "SELINUX=enforcing", "is_regex": false }, "expected": { "type": "is_true" }, "description": "SELinux must be set to enforcing mode" }
  ]
