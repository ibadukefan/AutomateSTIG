{
  "stig_id": "Apache_Tomcat_9_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-222930", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "sslProtocol\\s*=\\s*\"TLS\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat connector must use TLS protocol" },
    { "vuln_id": "V-222931", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "sslEnabledProtocols\\s*=\\s*\"TLSv1\\.2", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat must enable only TLS 1.2 or higher" },
    { "vuln_id": "V-222932", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "port\\s*=\\s*\"-1\".*shutdown", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat shutdown port must be disabled (set to -1)" },
    { "vuln_id": "V-222933", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "shutdown\\s*=\\s*\"SHUTDOWN\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat shutdown command must be changed from default is not acceptable - check negated" },
    { "vuln_id": "V-222934", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/web.xml", "pattern": "<param-name>listings</param-name>\\s*<param-value>false</param-value>", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat directory listings must be disabled" },
    { "vuln_id": "V-222935", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "className\\s*=\\s*\"org\\.apache\\.catalina\\.valves\\.AccessLogValve\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat access log valve must be configured" },
    { "vuln_id": "V-222936", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "pattern\\s*=\\s*\"%h\\s+%l\\s+%u\\s+%t", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat access log must use combined log format" },
    { "vuln_id": "V-222937", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/web.xml", "pattern": "<session-timeout>\\s*15\\s*</session-timeout>", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat session timeout must be set to 15 minutes" },
    { "vuln_id": "V-222938", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/web.xml", "pattern": "<error-page>\\s*<error-code>404</error-code>", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat must define a custom 404 error page" },
    { "vuln_id": "V-222939", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/web.xml", "pattern": "<error-page>\\s*<error-code>500</error-code>", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat must define a custom 500 error page" },
    { "vuln_id": "V-222940", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/web.xml", "pattern": "<cookie-config>\\s*<http-only>true</http-only>", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat session cookies must be HttpOnly" },
    { "vuln_id": "V-222941", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/web.xml", "pattern": "<cookie-config>.*<secure>true</secure>", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat session cookies must be marked Secure" },
    { "vuln_id": "V-222942", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "xpoweredBy\\s*=\\s*\"false\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat must not send X-Powered-By header" },
    { "vuln_id": "V-222943", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "server\\s*=\\s*\"\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat server header must be suppressed" },
    { "vuln_id": "V-222944", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "allowTrace\\s*=\\s*\"false\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat TRACE method must be disabled" },
    { "vuln_id": "V-222945", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "maxHttpHeaderSize\\s*=\\s*\"8192\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat maximum HTTP header size must be limited to 8192 bytes" },
    { "vuln_id": "V-222946", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "maxPostSize\\s*=\\s*\"-1\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat POST size must be limited (not unlimited)" },
    { "vuln_id": "V-222947", "platform": "linux", "check": { "type": "file_permission", "path": "/opt/tomcat/conf/server.xml", "owner": "tomcat", "group": null, "mode": "0600" }, "expected": { "type": "is_true" }, "description": "Tomcat server.xml must be mode 0600 and owned by tomcat user" },
    { "vuln_id": "V-222948", "platform": "linux", "check": { "type": "file_permission", "path": "/opt/tomcat/conf/web.xml", "owner": "tomcat", "group": null, "mode": "0600" }, "expected": { "type": "is_true" }, "description": "Tomcat web.xml must be mode 0600 and owned by tomcat user" },
    { "vuln_id": "V-222949", "platform": "linux", "check": { "type": "file_content", "path": "/opt/tomcat/conf/server.xml", "pattern": "autoDeploy\\s*=\\s*\"false\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Tomcat auto-deployment must be disabled" }
  ]
}
