{
  "stig_id": "MariaDB_10_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-266501",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'have_ssl';\"", "pattern": "have_ssl\\s+YES", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have SSL enabled"
    },
    {
      "vuln_id": "V-266502",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'ssl_cert';\"", "pattern": "ssl_cert\\s+\\S+\\.pem", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have ssl_cert configured"
    },
    {
      "vuln_id": "V-266503",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'ssl_key';\"", "pattern": "ssl_key\\s+\\S+\\.pem", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have ssl_key configured"
    },
    {
      "vuln_id": "V-266504",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'tls_version';\"", "pattern": "TLSv1\\.2|TLSv1\\.3", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must use TLS 1.2 or higher"
    },
    {
      "vuln_id": "V-266505",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'server_audit_logging';\"", "pattern": "server_audit_logging\\s+ON", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 server audit logging must be enabled"
    },
    {
      "vuln_id": "V-266506",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'server_audit_events';\"", "pattern": "CONNECT|QUERY|TABLE", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 server audit events must include CONNECT, QUERY, or TABLE"
    },
    {
      "vuln_id": "V-266507",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SELECT PLUGIN_NAME, PLUGIN_STATUS FROM INFORMATION_SCHEMA.PLUGINS WHERE PLUGIN_NAME='server_audit';\"", "pattern": "server_audit\\s+ACTIVE", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have the server_audit plugin installed and active"
    },
    {
      "vuln_id": "V-266508",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SELECT PLUGIN_NAME, PLUGIN_STATUS FROM INFORMATION_SCHEMA.PLUGINS WHERE PLUGIN_NAME='simple_password_check';\"", "pattern": "simple_password_check\\s+ACTIVE", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have the simple_password_check plugin installed and active"
    },
    {
      "vuln_id": "V-266509",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'simple_password_check_minimal_length';\"", "pattern": "simple_password_check_minimal_length\\s+(1[5-9]|[2-9][0-9])", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 minimum password length must be 15 or greater"
    },
    {
      "vuln_id": "V-266510",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'local_infile';\"", "pattern": "local_infile\\s+OFF", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have local_infile disabled"
    },
    {
      "vuln_id": "V-266511",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'log_bin';\"", "pattern": "log_bin\\s+ON", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have binary logging enabled"
    },
    {
      "vuln_id": "V-266512",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'log_error';\"", "pattern": "log_error\\s+\\S+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must have log_error configured to a file path"
    },
    {
      "vuln_id": "V-266513",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SELECT user, host FROM mysql.user WHERE authentication_string='' OR authentication_string IS NULL;\"", "pattern": "Empty set", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must not have accounts with empty passwords"
    },
    {
      "vuln_id": "V-266514",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'max_connect_errors';\"", "pattern": "max_connect_errors\\s+\\d+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must limit consecutive connection errors"
    },
    {
      "vuln_id": "V-266515",
      "platform": "linux",
      "check": { "type": "command", "command": "mysql -u root -e \"SHOW VARIABLES LIKE 'sql_mode';\"", "pattern": "STRICT_ALL_TABLES|STRICT_TRANS_TABLES", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MariaDB 10 must use strict SQL mode"
    }
  ]
}
