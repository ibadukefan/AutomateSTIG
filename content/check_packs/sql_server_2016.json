{
  "stig_id": "MS_SQL_Server_2016_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-213920",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "LoginMode" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server 2016 must use Windows Authentication mode (LoginMode=1)"
    },
    {
      "vuln_id": "V-213921",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "AuditLevel" },
      "expected": { "type": "equals", "value": 3 },
      "description": "SQL Server 2016 must audit both failed and successful login attempts (AuditLevel=3)"
    },
    {
      "vuln_id": "V-213922",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib", "value_name": "ForceEncryption" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server 2016 must force protocol encryption for all connections"
    },
    {
      "vuln_id": "V-213923",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib", "value_name": "Certificate" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server 2016 must have a TLS certificate configured"
    },
    {
      "vuln_id": "V-213925",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Tcp", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server 2016 TCP/IP protocol must be enabled"
    },
    {
      "vuln_id": "V-213926",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Np", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server 2016 Named Pipes protocol must be disabled"
    },
    {
      "vuln_id": "V-213930",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\Setup", "value_name": "PatchLevel" },
      "expected": { "type": "matches", "pattern": "13\\.0\\." },
      "description": "SQL Server 2016 must be at the latest patch level"
    },
    {
      "vuln_id": "V-213935",
      "platform": "windows",
      "check": { "type": "service", "name": "MSSQLSERVER", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "SQL Server 2016 database engine service must be running"
    },
    {
      "vuln_id": "V-213936",
      "platform": "windows",
      "check": { "type": "service", "name": "SQLSERVERAGENT", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "SQL Server 2016 Agent service must be running"
    },
    {
      "vuln_id": "V-213940",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "NumErrorLogs" },
      "expected": { "type": "greater_or_equal", "value": 12 },
      "description": "SQL Server 2016 must maintain at least 12 error log files"
    },
    {
      "vuln_id": "V-213941",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "DefaultData" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server 2016 default data directory must be configured"
    },
    {
      "vuln_id": "V-213942",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "DefaultLog" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server 2016 default log directory must be configured"
    },
    {
      "vuln_id": "V-213943",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "BackupDirectory" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server 2016 backup directory must be configured"
    },
    {
      "vuln_id": "V-213950",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Sm", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server 2016 Shared Memory protocol must be disabled for remote connections"
    },
    {
      "vuln_id": "V-213951",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Via", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server 2016 VIA protocol must be disabled"
    },
    {
      "vuln_id": "V-213955",
      "platform": "windows",
      "check": { "type": "service", "name": "SQLBrowser", "expected_status": "stopped" },
      "expected": { "type": "is_true" },
      "description": "SQL Server 2016 Browser service must be stopped unless required"
    },
    {
      "vuln_id": "V-213960",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "IsSaDisabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server 2016 sa account must be disabled"
    },
    {
      "vuln_id": "V-213961",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL13.MSSQLSERVER\\MSSQLServer", "value_name": "RemoteAccess" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server 2016 remote access must be disabled"
    },
    {
      "vuln_id": "V-213965",
      "platform": "windows",
      "check": { "type": "audit_policy", "subcategory": "Account Logon", "setting": "Success and Failure" },
      "expected": { "type": "contains", "substring": "Success" },
      "description": "Account logon events must be audited on the SQL Server 2016 host"
    },
    {
      "vuln_id": "V-213966",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "value_name": "LegalNoticeText" },
      "expected": { "type": "matches", "pattern": ".{10,}" },
      "description": "SQL Server 2016 host must display legal notice text before logon"
    }
  ]
}
