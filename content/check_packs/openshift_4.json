{
  "stig_id": "OpenShift_4_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-283001", "platform": "linux", "check": { "type": "command", "command": "oc get clusterrolebinding | grep -c 'cluster-admin'", "pattern": "^[0-3]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Cluster-admin role bindings must be limited to authorized service accounts" },
    { "vuln_id": "V-283002", "platform": "linux", "check": { "type": "command", "command": "oc get scc --no-headers | awk '{print $1}'", "pattern": "restricted", "is_regex": false }, "expected": { "type": "is_true" }, "description": "OpenShift must use Security Context Constraints including the restricted SCC" },
    { "vuln_id": "V-283003", "platform": "linux", "check": { "type": "command", "command": "oc get scc privileged -o jsonpath='{.users}'", "pattern": "system:admin", "is_regex": false }, "expected": { "type": "is_false" }, "description": "The privileged SCC must not be granted to unauthorized users" },
    { "vuln_id": "V-283004", "platform": "linux", "check": { "type": "command", "command": "oc get networkpolicy --all-namespaces --no-headers | wc -l", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Network policies must be defined across namespaces" },
    { "vuln_id": "V-283005", "platform": "linux", "check": { "type": "command", "command": "oc get apiserver cluster -o jsonpath='{.spec.encryption.type}'", "pattern": "(aescbc|aesgcm)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "etcd encryption must be enabled for secrets at rest" },
    { "vuln_id": "V-283006", "platform": "linux", "check": { "type": "command", "command": "oc get oauth cluster -o jsonpath='{.spec.identityProviders[*].type}'", "pattern": "(LDAP|OpenID|HTPasswd|Keystone|RequestHeader)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "OAuth identity providers must be configured (no kubeadmin)" },
    { "vuln_id": "V-283007", "platform": "linux", "check": { "type": "command", "command": "oc get secret kubeadmin -n kube-system 2>&1", "pattern": "not found", "is_regex": false }, "expected": { "type": "is_true" }, "description": "The kubeadmin account must be removed after identity providers are configured" },
    { "vuln_id": "V-283008", "platform": "linux", "check": { "type": "command", "command": "oc get oauth cluster -o jsonpath='{.spec.tokenConfig.accessTokenMaxAgeSeconds}'", "pattern": "^([1-9]\\d{0,4}|[1-2]\\d{4}|3[0-5]\\d{3}|36000)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "OAuth access token max age must be set to 10 hours or less" },
    { "vuln_id": "V-283009", "platform": "linux", "check": { "type": "command", "command": "oc get ingresscontroller default -n openshift-ingress-operator -o jsonpath='{.spec.defaultCertificate.name}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Ingress controller must use a custom TLS certificate" },
    { "vuln_id": "V-283010", "platform": "linux", "check": { "type": "command", "command": "oc get clusterlogforwarder instance -n openshift-logging -o jsonpath='{.spec.outputs[*].type}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Cluster logging and log forwarding must be configured" },
    { "vuln_id": "V-283011", "platform": "linux", "check": { "type": "command", "command": "oc get pods --all-namespaces -o jsonpath='{.items[?(@.spec.containers[*].securityContext.privileged==true)].metadata.name}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_false" }, "description": "Containers must not run in privileged mode" },
    { "vuln_id": "V-283012", "platform": "linux", "check": { "type": "command", "command": "oc get pods --all-namespaces -o jsonpath='{.items[?(@.spec.containers[*].securityContext.runAsUser==0)].metadata.name}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_false" }, "description": "Containers must not run as root user" },
    { "vuln_id": "V-283013", "platform": "linux", "check": { "type": "command", "command": "oc get project default -o jsonpath='{.metadata.annotations}'", "pattern": "openshift\\.io/node-selector", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Default project must have a node selector configured" },
    { "vuln_id": "V-283014", "platform": "linux", "check": { "type": "command", "command": "oc get kubeapiservers.operator.openshift.io cluster -o jsonpath='{.spec.observedConfig.auditConfig.policyConfiguration}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Audit policy must be configured on the API server" },
    { "vuln_id": "V-283015", "platform": "linux", "check": { "type": "command", "command": "oc get image.config.openshift.io/cluster -o jsonpath='{.spec.registrySources.allowedRegistries}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Allowed container registries must be explicitly configured" },
    { "vuln_id": "V-283016", "platform": "linux", "check": { "type": "command", "command": "oc get clusterrolebinding -o jsonpath='{.items[?(@.roleRef.name==\"self-provisioner\")].subjects}'", "pattern": "system:authenticated:oauth", "is_regex": false }, "expected": { "type": "is_false" }, "description": "Self-provisioner role must not be bound to authenticated users" },
    { "vuln_id": "V-283017", "platform": "linux", "check": { "type": "command", "command": "oc get scc anyuid -o jsonpath='{.users}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_false" }, "description": "The anyuid SCC must not be granted to unauthorized users" },
    { "vuln_id": "V-283018", "platform": "linux", "check": { "type": "command", "command": "oc get proxy cluster -o jsonpath='{.spec.trustedCA.name}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Cluster-wide proxy must have a trusted CA bundle configured" },
    { "vuln_id": "V-283019", "platform": "linux", "check": { "type": "command", "command": "oc get scheduler cluster -o jsonpath='{.spec.policy}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Scheduler policy must be configured for proper pod placement" },
    { "vuln_id": "V-283020", "platform": "linux", "check": { "type": "command", "command": "oc get limitrange -A --no-headers | wc -l", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "LimitRange resources must be configured across namespaces" }
  ]
}
