{
  "stig_id": "Hyper-V_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-260700",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Virtualization", "value_name": "SecureBoot" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Hyper-V must enable Secure Boot for Generation 2 VMs"
    },
    {
      "vuln_id": "V-260701",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Virtualization", "value_name": "EnableVTPM" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Hyper-V must enable virtual TPM for Generation 2 VMs"
    },
    {
      "vuln_id": "V-260702",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Virtualization\\GuestServices", "value_name": "DataExchangeEnabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Hyper-V Data Exchange integration service must be disabled unless required"
    },
    {
      "vuln_id": "V-260703",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Virtualization\\GuestServices", "value_name": "GuestServicesEnabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Hyper-V Guest Services integration service must be disabled unless required"
    },
    {
      "vuln_id": "V-260704",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows NT\\CurrentVersion\\Virtualization\\GuestServices", "value_name": "HeartbeatEnabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Hyper-V Heartbeat integration service must be enabled"
    },
    {
      "vuln_id": "V-260710",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\HyperV\\VirtualSwitch", "value_name": "MacSpoofing" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Hyper-V virtual switch must disable MAC address spoofing"
    },
    {
      "vuln_id": "V-260711",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\HyperV\\VirtualSwitch", "value_name": "DHCPGuard" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Hyper-V virtual switch must enable DHCP Guard"
    },
    {
      "vuln_id": "V-260712",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\HyperV\\VirtualSwitch", "value_name": "RouterGuard" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Hyper-V virtual switch must enable Router Guard"
    },
    {
      "vuln_id": "V-260713",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\HyperV\\VirtualSwitch", "value_name": "AllowTeaming" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Hyper-V must not allow NIC teaming on virtual switches unless required"
    },
    {
      "vuln_id": "V-260720",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\HyperV\\VirtualSwitch", "value_name": "VlanId" },
      "expected": { "type": "matches", "pattern": "\\d+" },
      "description": "Hyper-V virtual network adapters must be assigned to specific VLANs"
    },
    {
      "vuln_id": "V-260721",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows\\HyperV", "value_name": "DisableEnhancedSessionMode" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Hyper-V Enhanced Session Mode must be disabled unless required"
    },
    {
      "vuln_id": "V-260725",
      "platform": "windows",
      "check": { "type": "service", "name": "vmms", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "Hyper-V Virtual Machine Management service must be running"
    },
    {
      "vuln_id": "V-260726",
      "platform": "windows",
      "check": { "type": "service", "name": "vmcompute", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "Hyper-V Host Compute Service must be running"
    },
    {
      "vuln_id": "V-260730",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "value_name": "LegalNoticeText" },
      "expected": { "type": "matches", "pattern": ".{10,}" },
      "description": "Hyper-V host must display legal notice text before logon"
    },
    {
      "vuln_id": "V-260731",
      "platform": "windows",
      "check": { "type": "audit_policy", "subcategory": "Logon/Logoff", "setting": "Success and Failure" },
      "expected": { "type": "contains", "substring": "Success" },
      "description": "Logon events must be audited on the Hyper-V host"
    }
  ]
}
