    {
      "vuln_id": "V-218735",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileMethod" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS 8.5 log files must include request method"
    },
    {
      "vuln_id": "V-218736",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp\\Configuration", "value_name": "LogExtFileHttpStatus" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS 8.5 log files must include HTTP status"
    },
    {
      "vuln_id": "V-218740",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "MaxFieldLength" },
      "expected": { "type": "less_or_equal", "value": 65534 },
      "description": "IIS 8.5 MaxFieldLength must be configured to limit header size"
    },
    {
      "vuln_id": "V-218741",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "MaxRequestBytes" },
      "expected": { "type": "less_or_equal", "value": 16777216 },
      "description": "IIS 8.5 MaxRequestBytes must be configured to limit request size"
    },
    {
      "vuln_id": "V-218745",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "EnableNonUTF8" },
      "expected": { "type": "equals", "value": 0 },
      "description": "IIS 8.5 must not allow non-UTF8 URLs"
    },
    {
      "vuln_id": "V-218746",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "FavorUTF8" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS 8.5 must favor UTF-8 encoding"
    },
    {
      "vuln_id": "V-218750",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Services\\HTTP\\Parameters", "value_name": "DisableServerHeader" },
      "expected": { "type": "equals", "value": 1 },
      "description": "IIS 8.5 must suppress the server version in HTTP headers"
    },
    {
      "vuln_id": "V-218755",
      "platform": "windows",
      "check": { "type": "service", "name": "W3SVC", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "World Wide Web Publishing Service must be running on IIS 8.5 server"
    },
    {
      "vuln_id": "V-218756",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\InetStp", "value_name": "MajorVersion" },
      "expected": { "type": "greater_or_equal", "value": 8 },
      "description": "IIS must be version 8.5 or later"
