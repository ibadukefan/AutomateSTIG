{
  "stig_id": "HashiCorp_Vault_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-288001", "platform": "linux", "check": { "type": "command", "command": "vault audit list -format=json 2>/dev/null | grep -c 'type'", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault must have at least one audit device enabled" },
    { "vuln_id": "V-288002", "platform": "linux", "check": { "type": "command", "command": "vault status -format=json | grep '\"sealed\"'", "pattern": "false", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Vault must be in an unsealed and operational state" },
    { "vuln_id": "V-288003", "platform": "linux", "check": { "type": "command", "command": "vault read sys/seal-status -format=json | grep '\"type\"'", "pattern": "(shamir|awskms|azurekeyvault|gcpckms|transit|pkcs11)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault must use a supported seal mechanism" },
    { "vuln_id": "V-288004", "platform": "linux", "check": { "type": "command", "command": "vault status -format=json | grep '\"cluster_name\"'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault must be configured as a cluster for high availability" },
    { "vuln_id": "V-288005", "platform": "linux", "check": { "type": "command", "command": "vault auth list -format=json 2>/dev/null | grep '\"type\"'", "pattern": "(ldap|oidc|cert|aws|azure|gcp|kubernetes|saml)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault must be configured with an enterprise authentication method" },
    { "vuln_id": "V-288006", "platform": "linux", "check": { "type": "command", "command": "vault policy list 2>/dev/null", "pattern": "default", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Vault must have a default policy configured" },
    { "vuln_id": "V-288007", "platform": "linux", "check": { "type": "command", "command": "vault policy read root 2>&1", "pattern": "(No policy|not found|permission denied)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Root token must be revoked after initial setup" },
    { "vuln_id": "V-288008", "platform": "linux", "check": { "type": "command", "command": "vault read sys/config/ui -format=json 2>/dev/null | grep 'enabled'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault UI configuration must be reviewed for access control" },
    { "vuln_id": "V-288009", "platform": "linux", "check": { "type": "command", "command": "vault secrets list -format=json 2>/dev/null | grep '\"type\"'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault secrets engines must be properly configured" },
    { "vuln_id": "V-288010", "platform": "linux", "check": { "type": "command", "command": "vault read sys/config/auditing/request-headers -format=json 2>/dev/null", "pattern": "X-Forwarded-For", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Vault audit device must log client IP via X-Forwarded-For header" },
    { "vuln_id": "V-288011", "platform": "linux", "check": { "type": "command", "command": "vault read sys/auth/token/tune -format=json 2>/dev/null | grep 'default_lease_ttl'", "pattern": "\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Default token lease TTL must be configured" },
    { "vuln_id": "V-288012", "platform": "linux", "check": { "type": "command", "command": "vault read sys/auth/token/tune -format=json 2>/dev/null | grep 'max_lease_ttl'", "pattern": "\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Maximum token lease TTL must be configured" },
    { "vuln_id": "V-288013", "platform": "linux", "check": { "type": "command", "command": "vault read sys/config/cors -format=json 2>/dev/null | grep 'allowed_origins'", "pattern": "\\*", "is_regex": false }, "expected": { "type": "is_false" }, "description": "CORS allowed origins must not use wildcard (*)" },
    { "vuln_id": "V-288014", "platform": "linux", "check": { "type": "command", "command": "cat /etc/vault.d/vault.hcl | grep 'tls_cert_file'", "pattern": "tls_cert_file\\s*=", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Vault listener must be configured with a TLS certificate" },
    { "vuln_id": "V-288015", "platform": "linux", "check": { "type": "command", "command": "cat /etc/vault.d/vault.hcl | grep 'tls_min_version'", "pattern": "tls12", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Vault TLS minimum version must be set to TLS 1.2" }
  ]
}
