{
  "stig_id": "Exchange_Server_2016_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-259860",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.2\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Exchange 2016 server must have TLS 1.2 enabled"
    },
    {
      "vuln_id": "V-259861",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\SSL 2.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SSL 2.0 must be disabled on the Exchange 2016 server"
    },
    {
      "vuln_id": "V-259862",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\SSL 3.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SSL 3.0 must be disabled on the Exchange 2016 server"
    },
    {
      "vuln_id": "V-259863",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.0 must be disabled on the Exchange 2016 server"
    },
    {
      "vuln_id": "V-259864",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.1\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.1 must be disabled on the Exchange 2016 server"
    },
    {
      "vuln_id": "V-259865",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-AdminAuditLogConfig | Select-Object AdminAuditLogEnabled | Format-List\"", "pattern": "AdminAuditLogEnabled\\s*:\\s*True", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 admin audit logging must be enabled"
    },
    {
      "vuln_id": "V-259866",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-MailboxAuditBypassAssociation -ResultSize Unlimited | Where-Object {$_.AuditBypassEnabled -eq $true} | Measure-Object | Select-Object Count | Format-List\"", "pattern": "Count\\s*:\\s*0", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 mailbox audit bypass must not be configured for any accounts"
    },
    {
      "vuln_id": "V-259867",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-OwaVirtualDirectory | Select-Object FormsAuthentication | Format-List\"", "pattern": "FormsAuthentication\\s*:\\s*True", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 OWA must use forms-based authentication"
    },
    {
      "vuln_id": "V-259868",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-OwaVirtualDirectory | Select-Object ExternalAuthenticationMethods | Format-List\"", "pattern": "ExternalAuthenticationMethods\\s*:.*Fba", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 OWA external authentication must be forms-based"
    },
    {
      "vuln_id": "V-259870",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-TransportConfig | Select-Object ExternalPostmasterAddress | Format-List\"", "pattern": "ExternalPostmasterAddress\\s*:\\s*\\S+@\\S+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 must have an external postmaster address configured"
    },
    {
      "vuln_id": "V-259871",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-TransportConfig | Select-Object MaxReceiveSize | Format-List\"", "pattern": "MaxReceiveSize\\s*:\\s*\\d+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 must limit maximum receive message size"
    },
    {
      "vuln_id": "V-259872",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-TransportConfig | Select-Object MaxSendSize | Format-List\"", "pattern": "MaxSendSize\\s*:\\s*\\d+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 must limit maximum send message size"
    },
    {
      "vuln_id": "V-259873",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-ReceiveConnector | Select-Object Name,RequireTLS | Format-List\"", "pattern": "RequireTLS\\s*:\\s*True", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 receive connectors must require TLS"
    },
    {
      "vuln_id": "V-259874",
      "platform": "windows",
      "check": { "type": "command", "command": "powershell -Command \"Get-SendConnector | Select-Object Name,RequireTLS | Format-List\"", "pattern": "RequireTLS\\s*:\\s*True", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Exchange 2016 send connectors must require TLS"
    },
    {
      "vuln_id": "V-259875",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\ExchangeServer\\v15\\Setup", "value_name": "MsiInstallPath" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "Exchange 2016 must be installed to a designated directory"
    }
  ]
}
