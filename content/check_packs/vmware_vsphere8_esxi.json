{
  "stig_id": "VMware_vSphere_8_ESXi_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-258700",
      "platform": "linux",
      "check": { "type": "command", "command": "vim-cmd hostsvc/hostsummary | grep -i lockdownMode", "pattern": "lockdownNormal|lockdownStrict", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi must enable lockdown mode to restrict direct host access"
    },
    {
      "vuln_id": "V-258701",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /UserVars/ESXiShellInteractiveTimeOut", "pattern": "Int Value:\\s+[1-9]", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi shell interactive timeout must be configured"
    },
    {
      "vuln_id": "V-258702",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /UserVars/ESXiShellTimeOut", "pattern": "Int Value:\\s+[1-9]", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi shell timeout must be set to automatically disable shell"
    },
    {
      "vuln_id": "V-258703",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /DCUI/Access", "pattern": "String Value:\\s+root$", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "DCUI access must be restricted to root user only"
    },
    {
      "vuln_id": "V-258704",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /UserVars/DcuiTimeOut", "pattern": "Int Value:\\s+[1-9]", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "DCUI idle timeout must be configured"
    },
    {
      "vuln_id": "V-258705",
      "platform": "linux",
      "check": { "type": "command", "command": "vim-cmd hostsvc/advopt/view Config.HostAgent.plugins.solo.enableMob", "pattern": "false", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "Managed Object Browser (MOB) must be disabled"
    },
    {
      "vuln_id": "V-258706",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system security fips140 ssh get", "pattern": "Enabled:\\s+true", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi must enable FIPS 140-2/140-3 mode for SSH"
    },
    {
      "vuln_id": "V-258707",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /UserVars/ESXiVPsDisabledProtocols", "pattern": "tlsv1,tlsv1.1,sslv3", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "ESXi must disable TLS 1.0, TLS 1.1, and SSL 3.0 (only TLS 1.2 allowed)"
    },
    {
      "vuln_id": "V-258708",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /Security/PasswordQualityControl", "pattern": "retry=3 min=disabled,disabled,disabled,disabled,15", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "ESXi password quality must enforce complexity requirements"
    },
    {
      "vuln_id": "V-258709",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /Security/PasswordHistory", "pattern": "Int Value:\\s+5", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi must prohibit reuse of the last 5 passwords"
    },
    {
      "vuln_id": "V-258710",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /Security/AccountLockFailures", "pattern": "Int Value:\\s+[1-5]$", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi account lockout must be set to 5 or fewer failed attempts"
    },
    {
      "vuln_id": "V-258711",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /Security/AccountUnlockTime", "pattern": "Int Value:\\s+900", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi account unlock time must be at least 900 seconds (15 minutes)"
    },
    {
      "vuln_id": "V-258712",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli network firewall get", "pattern": "Enabled:\\s+true", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi host firewall must be enabled"
    },
    {
      "vuln_id": "V-258713",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli network firewall get", "pattern": "Default Action:\\s+DROP", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi host firewall default policy must be set to DROP"
    },
    {
      "vuln_id": "V-258714",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system snmp get", "pattern": "Enable:\\s+false", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "SNMP must be disabled unless SNMPv3 is configured with proper authentication"
    },
    {
      "vuln_id": "V-258715",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system snmp get", "pattern": "communities:", "is_regex": false },
      "expected": { "type": "is_false" },
      "description": "SNMP community strings must not be configured"
    },
    {
      "vuln_id": "V-258716",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system ntp get", "pattern": "Enabled:\\s+true", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "NTP service must be enabled for time synchronization"
    },
    {
      "vuln_id": "V-258717",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system ntp config get", "pattern": "Server:", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "NTP must be configured with an authoritative time source"
    },
    {
      "vuln_id": "V-258718",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system syslog config get", "pattern": "Remote Host:", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "Remote syslog host must be configured"
    },
    {
      "vuln_id": "V-258719",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli system settings advanced list -o /Syslog/global/logHost", "pattern": "String Value:\\s+.+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Syslog global log host must point to a remote server"
    },
    {
      "vuln_id": "V-258720",
      "platform": "linux",
      "check": { "type": "command", "command": "vim-cmd hostsvc/advopt/view Config.HostAgent.log.level", "pattern": "info", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "ESXi host agent log level must be set to info"
    },
    {
      "vuln_id": "V-258721",
      "platform": "linux",
      "check": { "type": "command", "command": "vim-cmd hostsvc/advopt/view Config.Etc.motd", "pattern": ".{10,}", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi must display a DoD-approved login banner (MOTD)"
    },
    {
      "vuln_id": "V-258722",
      "platform": "linux",
      "check": { "type": "command", "command": "vim-cmd hostsvc/advopt/view Config.Etc.issue", "pattern": ".{10,}", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi must display a DoD-approved SSH banner (/etc/issue)"
    },
    {
      "vuln_id": "V-258723",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi SSH must be configured to display the login banner"
    },
    {
      "vuln_id": "V-258724",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Compression\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi SSH must disable compression"
    },
    {
      "vuln_id": "V-258725",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "GatewayPorts\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi SSH must disable gateway ports"
    },
    {
      "vuln_id": "V-258726",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi SSH must disable X11 forwarding"
    },
    {
      "vuln_id": "V-258727",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitTunnel\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi SSH must disable tunneling"
    },
    {
      "vuln_id": "V-258728",
      "platform": "linux",
      "check": { "type": "command", "command": "esxcli software acceptance get", "pattern": "PartnerSupported|VMwareCertified|VMwareAccepted", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "ESXi software acceptance level must be PartnerSupported or higher"
    },
    {
      "vuln_id": "V-258729",
      "platform": "linux",
      "check": {
        "type": "all",
        "checks": [
          { "type": "command", "command": "esxcli network firewall get", "pattern": "Enabled:\\s+true", "is_regex": true },
          { "type": "command", "command": "esxcli system ntp get", "pattern": "Enabled:\\s+true", "is_regex": true },
          { "type": "command", "command": "esxcli system syslog config get", "pattern": "Remote Host:", "is_regex": false }
        ]
      },
      "expected": { "type": "all_pass" },
      "description": "Firewall, NTP, and remote syslog must all be properly configured"
    }
  ]
}
