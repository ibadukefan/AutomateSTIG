{
  "stig_id": "Amazon_Linux_2_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-252600", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Amazon Linux 2 SSH must not allow direct root login" },
    { "vuln_id": "V-252601", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must not allow empty passwords" },
    { "vuln_id": "V-252602", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveInterval must be set" },
    { "vuln_id": "V-252603", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveCountMax\\s+[01]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveCountMax must be 1 or less" },
    { "vuln_id": "V-252604", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must display a login banner" },
    { "vuln_id": "V-252605", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH X11 forwarding must be disabled" },
    { "vuln_id": "V-252606", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Ciphers\\s+.*aes256-ctr", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use FIPS 140-2 compliant ciphers" },
    { "vuln_id": "V-252610", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.ip_forward" }, "expected": { "type": "equals", "value": "0" }, "description": "IP forwarding must be disabled" },
    { "vuln_id": "V-252611", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_source_route" }, "expected": { "type": "equals", "value": "0" }, "description": "Source-routed packets must not be accepted" },
    { "vuln_id": "V-252612", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.accept_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "ICMP redirects must not be accepted" },
    { "vuln_id": "V-252613", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.conf.all.send_redirects" }, "expected": { "type": "equals", "value": "0" }, "description": "System must not send ICMP redirects" },
    { "vuln_id": "V-252614", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.tcp_syncookies" }, "expected": { "type": "equals", "value": "1" }, "description": "TCP SYN cookies must be enabled" },
    { "vuln_id": "V-252615", "platform": "linux", "check": { "type": "sysctl", "key": "kernel.randomize_va_space" }, "expected": { "type": "equals", "value": "2" }, "description": "ASLR must be fully enabled" },
    { "vuln_id": "V-252620", "platform": "linux", "check": { "type": "service", "name": "auditd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Audit daemon must be running" },
    { "vuln_id": "V-252621", "platform": "linux", "check": { "type": "service", "name": "sshd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "SSH daemon must be running" },
    { "vuln_id": "V-252622", "platform": "linux", "check": { "type": "service", "name": "iptables", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "iptables firewall must be active" },
    { "vuln_id": "V-252623", "platform": "linux", "check": { "type": "service", "name": "amazon-cloudwatch-agent", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "CloudWatch agent must be running for centralized logging" },
    { "vuln_id": "V-252630", "platform": "linux", "check": { "type": "package", "name": "aide", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "AIDE must be installed for file integrity checking" },
    { "vuln_id": "V-252631", "platform": "linux", "check": { "type": "package", "name": "audit", "should_be_installed": true }, "expected": { "type": "is_true" }, "description": "Audit package must be installed" },
    { "vuln_id": "V-252632", "platform": "linux", "check": { "type": "package", "name": "telnet-server", "should_be_installed": false }, "expected": { "type": "is_true" }, "description": "Telnet server must not be installed" },
    { "vuln_id": "V-252633", "platform": "linux", "check": { "type": "package", "name": "rsh-server", "should_be_installed": false }, "expected": { "type": "is_true" }, "description": "RSH server must not be installed" },
    { "vuln_id": "V-252640", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MAX_DAYS\\s+60", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Maximum password age must be 60 days or less" },
    { "vuln_id": "V-252641", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MIN_DAYS\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Minimum password age must be at least 1 day" },
    { "vuln_id": "V-252642", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "ENCRYPT_METHOD\\s+SHA512", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Passwords must be hashed with SHA-512" },
    { "vuln_id": "V-252643", "platform": "linux", "check": { "type": "file_content", "path": "/etc/security/pwquality.conf", "pattern": "minlen\\s*=\\s*1[5-9]|minlen\\s*=\\s*[2-9][0-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Password quality must require minimum length of 15" }
  ]
}
