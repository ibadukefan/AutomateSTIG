    { "vuln_id": "V-234842", "platform": "linux", "check": { "type": "service", "name": "sshd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "SSH daemon must be running" },
    { "vuln_id": "V-234850", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "ENCRYPT_METHOD\\s+SHA512", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Passwords must be hashed with SHA-512" }
