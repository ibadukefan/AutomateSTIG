    { "vuln_id": "V-234806", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "MACs\\s+.*hmac-sha2-256", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use FIPS 140-2 compliant MACs" },
