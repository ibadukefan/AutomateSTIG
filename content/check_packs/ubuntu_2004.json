{
  "stig_id": "Ubuntu_20.04_LTS_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-238196",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitRootLogin\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Ubuntu 20.04 SSH must not allow direct root login"
    },
    {
      "vuln_id": "V-238197",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "SSH must not allow empty passwords"
    },
    {
      "vuln_id": "V-238198",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+[1-9]", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "SSH ClientAliveInterval must be set"
    },
    {
      "vuln_id": "V-238199",
      "platform": "linux",
