{
  "stig_id": "GCP_Cloud_SQL_STIG",
  "platform": "generic",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-282001", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.ipConfiguration.requireSsl)'", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL instance must require SSL for all connections" },
    { "vuln_id": "V-282002", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.backupConfiguration.enabled)'", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Automated backups must be enabled on the Cloud SQL instance" },
    { "vuln_id": "V-282003", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.backupConfiguration.binaryLogEnabled)'", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Binary logging must be enabled for point-in-time recovery" },
    { "vuln_id": "V-282004", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.ipConfiguration.authorizedNetworks)'", "pattern": "0\\.0\\.0\\.0/0", "is_regex": true }, "expected": { "type": "is_false" }, "description": "Cloud SQL must not authorize the 0.0.0.0/0 network (public access)" },
    { "vuln_id": "V-282005", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.databaseFlags)' | grep 'log_connections'", "pattern": "on", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL database flag log_connections must be enabled" },
    { "vuln_id": "V-282006", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.databaseFlags)' | grep 'log_disconnections'", "pattern": "on", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL database flag log_disconnections must be enabled" },
    { "vuln_id": "V-282007", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.databaseFlags)' | grep 'log_min_duration_statement'", "pattern": "-1", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL log_min_duration_statement must be set to -1 (disabled) to prevent logging sensitive queries" },
    { "vuln_id": "V-282008", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.databaseFlags)' | grep 'log_checkpoints'", "pattern": "on", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL database flag log_checkpoints must be enabled" },
    { "vuln_id": "V-282009", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.ipConfiguration.ipv4Enabled)'", "pattern": "False", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL instance must use private IP and disable public IPv4" },
    { "vuln_id": "V-282010", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.availabilityType)'", "pattern": "REGIONAL", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL instance must be configured for high availability (REGIONAL)" },
    { "vuln_id": "V-282011", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.maintenanceWindow)'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Cloud SQL maintenance window must be configured" },
    { "vuln_id": "V-282012", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.backupConfiguration.backupRetentionSettings.retainedBackups)'", "pattern": "^([7-9]|[1-9]\\d+)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Backup retention must be at least 7 retained backups" },
    { "vuln_id": "V-282013", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.databaseFlags)' | grep 'local_infile'", "pattern": "off", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL database flag local_infile must be disabled" },
    { "vuln_id": "V-282014", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.storageAutoResize)'", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Cloud SQL storage auto-resize must be enabled" },
    { "vuln_id": "V-282015", "platform": "generic", "check": { "type": "command", "command": "gcloud sql instances describe $INSTANCE --format='value(settings.deletionProtectionEnabled)'", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Deletion protection must be enabled on the Cloud SQL instance" }
  ]
}
