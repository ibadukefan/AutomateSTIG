      "check": { "type": "file_content", "path": "/etc/postfix/main.cf", "pattern": "smtpd_tls_security_level\\s*=\\s*(may|encrypt)", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Postfix must enable TLS for inbound SMTP connections"
