      "check": { "type": "file_content", "path": "/etc/postfix/main.cf", "pattern": "smtpd_tls_cert_file\\s*=\\s*\\S+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Postfix must have a TLS certificate file configured"
    },
    {
      "vuln_id": "V-263502",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/postfix/main.cf", "pattern": "smtpd_tls_key_file\\s*=\\s*\\S+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Postfix must have a TLS key file configured"
    },
    {
