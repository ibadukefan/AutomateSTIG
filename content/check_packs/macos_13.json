{
  "stig_id": "Apple_macOS_13_STIG",
  "platform": "generic",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-257500", "platform": "generic", "check": { "type": "command", "command": "fdesetup status", "pattern": "FileVault is On", "is_regex": false }, "expected": { "type": "is_true" }, "description": "FileVault full-disk encryption must be enabled" },
    { "vuln_id": "V-257501", "platform": "generic", "check": { "type": "command", "command": "spctl --status", "pattern": "assessments enabled", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Gatekeeper must be enabled" },
    { "vuln_id": "V-257502", "platform": "generic", "check": { "type": "command", "command": "csrutil status", "pattern": "System Integrity Protection status: enabled", "is_regex": false }, "expected": { "type": "is_true" }, "description": "System Integrity Protection (SIP) must be enabled" },
    { "vuln_id": "V-257503", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.alf globalstate", "pattern": "^[12]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "macOS application firewall must be enabled" },
    { "vuln_id": "V-257504", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.loginwindow autoLoginUser 2>&1", "pattern": "does not exist", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Auto-login must be disabled" },
    { "vuln_id": "V-257505", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.screensaver askForPassword", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Screen saver must require a password to unlock" },
    { "vuln_id": "V-257506", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.screensaver askForPasswordDelay", "pattern": "^[0-5]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Screen saver password grace period must be 5 seconds or less" },
    { "vuln_id": "V-257507", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.screensaver idleTime", "pattern": "^(60|120|180|240|300|360|420|480|540|600|660|720|780|840|900)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Screen saver must activate within 15 minutes of idle time" },
    { "vuln_id": "V-257508", "platform": "generic", "check": { "type": "command", "command": "pwpolicy -getaccountpolicies 2>&1", "pattern": "policyAttributeMinimumLength", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Password policy must enforce a minimum length" },
    { "vuln_id": "V-257509", "platform": "generic", "check": { "type": "command", "command": "pwpolicy -getaccountpolicies 2>&1", "pattern": "policyAttributeMaximumFailedAuthentications", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Password policy must enforce an account lockout threshold" },
    { "vuln_id": "V-257510", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.loginwindow GuestEnabled", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Guest account must be disabled" },
    { "vuln_id": "V-257511", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.loginwindow LoginwindowText 2>&1", "pattern": ".{10,}", "is_regex": true }, "expected": { "type": "is_true" }, "description": "A login window banner must be displayed" },
    { "vuln_id": "V-257512", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.loginwindow SHOWFULLNAME", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Login window must display name and password fields" },
    { "vuln_id": "V-257513", "platform": "generic", "check": { "type": "command", "command": "/usr/sbin/systemsetup -getremotelogin", "pattern": "Remote Login:\\s*Off", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Remote login (SSH) must be disabled unless required" },
    { "vuln_id": "V-257514", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.Bluetooth PrefKeyServicesEnabled 2>&1", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Bluetooth sharing must be disabled" },
    { "vuln_id": "V-257515", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.NetworkBrowser DisableAirDrop 2>&1", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "AirDrop must be disabled" },
    { "vuln_id": "V-257516", "platform": "generic", "check": { "type": "command", "command": "launchctl list | grep -c com.apple.auditd", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Audit service (auditd) must be running" },
    { "vuln_id": "V-257517", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.SoftwareUpdate AutomaticCheckEnabled", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Automatic software update check must be enabled" },
    { "vuln_id": "V-257518", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.SoftwareUpdate CriticalUpdateInstall", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Critical security updates must install automatically" },
    { "vuln_id": "V-257519", "platform": "generic", "check": { "type": "command", "command": "system_profiler SPFirewallDataType | grep 'Stealth Mode'", "pattern": "Stealth Mode:\\s+enabled", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Firewall stealth mode must be enabled" }
  ]
}
