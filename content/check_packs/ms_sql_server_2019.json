{
  "stig_id": "MS_SQL_Server_2019_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-255330",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "LoginMode" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server must use Windows Authentication mode (LoginMode=1)"
    },
    {
      "vuln_id": "V-255331",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "AuditLevel" },
      "expected": { "type": "equals", "value": 3 },
      "description": "SQL Server must audit both failed and successful login attempts (AuditLevel=3)"
    },
    {
      "vuln_id": "V-255332",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib", "value_name": "ForceEncryption" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server must force protocol encryption for all connections"
    },
    {
      "vuln_id": "V-255333",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib", "value_name": "Certificate" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server must have a TLS certificate configured"
    },
    {
      "vuln_id": "V-255335",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Tcp", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server TCP/IP protocol must be enabled"
    },
    {
      "vuln_id": "V-255336",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Np", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server Named Pipes protocol must be disabled"
    },
    {
      "vuln_id": "V-255340",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\Setup", "value_name": "PatchLevel" },
      "expected": { "type": "matches", "pattern": "15\\.0\\." },
      "description": "SQL Server 2019 must be at the latest patch level"
    },
    {
      "vuln_id": "V-255345",
      "platform": "windows",
      "check": { "type": "service", "name": "MSSQLSERVER", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "SQL Server database engine service must be running"
    },
    {
      "vuln_id": "V-255346",
      "platform": "windows",
      "check": { "type": "service", "name": "SQLSERVERAGENT", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "SQL Server Agent service must be running"
    },
    {
      "vuln_id": "V-255350",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "NumErrorLogs" },
      "expected": { "type": "greater_or_equal", "value": 12 },
      "description": "SQL Server must maintain at least 12 error log files"
    },
    {
      "vuln_id": "V-255351",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "DefaultData" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server default data directory must be configured"
    },
    {
      "vuln_id": "V-255352",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "DefaultLog" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server default log directory must be configured"
    },
    {
      "vuln_id": "V-255353",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "BackupDirectory" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "SQL Server backup directory must be configured"
    },
    {
      "vuln_id": "V-255360",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Sm", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server Shared Memory protocol must be disabled for remote connections"
    },
    {
      "vuln_id": "V-255361",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer\\SuperSocketNetLib\\Via", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server VIA protocol must be disabled"
    },
    {
      "vuln_id": "V-255365",
      "platform": "windows",
      "check": { "type": "service", "name": "SQLBrowser", "expected_status": "stopped" },
      "expected": { "type": "is_true" },
      "description": "SQL Server Browser service must be stopped unless required"
    },
    {
      "vuln_id": "V-255370",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "IsSaDisabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SQL Server sa account must be disabled"
    },
    {
      "vuln_id": "V-255371",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Microsoft SQL Server\\MSSQL15.MSSQLSERVER\\MSSQLServer", "value_name": "RemoteAccess" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SQL Server remote access must be disabled"
    },
    {
      "vuln_id": "V-255375",
      "platform": "windows",
      "check": { "type": "audit_policy", "subcategory": "Account Logon", "setting": "Success and Failure" },
      "expected": { "type": "contains", "substring": "Success" },
      "description": "Account logon events must be audited on the SQL server host"
    },
    {
      "vuln_id": "V-255376",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "value_name": "LegalNoticeText" },
      "expected": { "type": "matches", "pattern": ".{10,}" },
      "description": "SQL Server host must display legal notice text before logon"
    }
  ]
}
