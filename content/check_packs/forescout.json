{
  "stig_id": "Forescout_STIG",
  "platform": "generic",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-291001", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/tls --header 'Authorization: Bearer $TOKEN' | grep 'min_version'", "pattern": "TLSv1\\.2", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout must enforce TLS 1.2 or higher for all connections" },
    { "vuln_id": "V-291002", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/auth --header 'Authorization: Bearer $TOKEN' | grep 'method'", "pattern": "(LDAP|RADIUS|SAML|certificate)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout must use an enterprise authentication provider" },
    { "vuln_id": "V-291003", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/audit --header 'Authorization: Bearer $TOKEN' | grep 'enabled'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Forescout audit logging must be enabled" },
    { "vuln_id": "V-291004", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/audit/syslog --header 'Authorization: Bearer $TOKEN' | grep 'enabled'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Forescout must forward audit logs to a syslog server" },
    { "vuln_id": "V-291005", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/policies --header 'Authorization: Bearer $TOKEN' | grep -c 'policy_id'", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout must have at least one active policy configured" },
    { "vuln_id": "V-291006", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/session --header 'Authorization: Bearer $TOKEN' | grep 'timeout'", "pattern": "\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Session timeout must be configured on the Forescout console" },
    { "vuln_id": "V-291007", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/password-policy --header 'Authorization: Bearer $TOKEN' | grep 'min_length'", "pattern": "^(1[2-9]|[2-9]\\d+)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout password policy must enforce a minimum length of 12 characters" },
    { "vuln_id": "V-291008", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/password-policy --header 'Authorization: Bearer $TOKEN' | grep 'lockout_threshold'", "pattern": "^[1-5]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Account lockout must be enforced after no more than 5 failed attempts" },
    { "vuln_id": "V-291009", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/banner --header 'Authorization: Bearer $TOKEN' | grep 'text'", "pattern": ".{10,}", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout must display a login warning banner" },
    { "vuln_id": "V-291010", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/ntp --header 'Authorization: Bearer $TOKEN' | grep 'server'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout must be configured with an authoritative NTP source" },
    { "vuln_id": "V-291011", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/ha --header 'Authorization: Bearer $TOKEN' | grep 'enabled'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "High availability must be configured for the Forescout deployment" },
    { "vuln_id": "V-291012", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/certificate --header 'Authorization: Bearer $TOKEN' | grep 'issuer'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Forescout must use a certificate issued by a trusted CA" },
    { "vuln_id": "V-291013", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/roles --header 'Authorization: Bearer $TOKEN' | grep -c 'role_name'", "pattern": "^[2-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Role-based access control must be configured with multiple roles" },
    { "vuln_id": "V-291014", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/updates --header 'Authorization: Bearer $TOKEN' | grep 'auto_update'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Forescout plugin updates must be configured for automatic deployment" },
    { "vuln_id": "V-291015", "platform": "generic", "check": { "type": "command", "command": "curl -sk https://$FORESCOUT_HOST/api/v1/system/backup --header 'Authorization: Bearer $TOKEN' | grep 'schedule'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Automated backup schedule must be configured for the Forescout appliance" }
  ]
}
