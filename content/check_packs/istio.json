{
  "stig_id": "Istio_Service_Mesh_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-285001", "platform": "linux", "check": { "type": "command", "command": "kubectl get peerauthentication -n istio-system -o jsonpath='{.items[?(@.metadata.name==\"default\")].spec.mtls.mode}'", "pattern": "STRICT", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Istio must enforce STRICT mTLS mesh-wide via PeerAuthentication" },
    { "vuln_id": "V-285002", "platform": "linux", "check": { "type": "command", "command": "kubectl get authorizationpolicy --all-namespaces --no-headers | wc -l", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Authorization policies must be defined across namespaces" },
    { "vuln_id": "V-285003", "platform": "linux", "check": { "type": "command", "command": "istioctl proxy-status 2>/dev/null | grep -c 'SYNCED'", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "All Envoy sidecars must be in SYNCED state with the control plane" },
    { "vuln_id": "V-285004", "platform": "linux", "check": { "type": "command", "command": "kubectl get configmap istio -n istio-system -o jsonpath='{.data.mesh}' | grep 'accessLogFile'", "pattern": "/dev/stdout", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Istio access logging must be enabled on all Envoy proxies" },
    { "vuln_id": "V-285005", "platform": "linux", "check": { "type": "command", "command": "kubectl get configmap istio -n istio-system -o jsonpath='{.data.mesh}' | grep 'enableTracing'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Distributed tracing must be enabled in the Istio mesh" },
    { "vuln_id": "V-285006", "platform": "linux", "check": { "type": "command", "command": "kubectl get gateway --all-namespaces -o jsonpath='{.items[*].spec.servers[*].tls.mode}'", "pattern": "(SIMPLE|MUTUAL|ISTIO_MUTUAL)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Istio gateways must be configured with TLS" },
    { "vuln_id": "V-285007", "platform": "linux", "check": { "type": "command", "command": "kubectl get gateway --all-namespaces -o jsonpath='{.items[*].spec.servers[*].tls.minProtocolVersion}'", "pattern": "TLSV1_2", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Istio gateways must enforce TLS 1.2 or higher" },
    { "vuln_id": "V-285008", "platform": "linux", "check": { "type": "command", "command": "kubectl get destinationrule --all-namespaces -o jsonpath='{.items[*].spec.trafficPolicy.tls.mode}'", "pattern": "ISTIO_MUTUAL", "is_regex": false }, "expected": { "type": "is_true" }, "description": "DestinationRules must enforce ISTIO_MUTUAL TLS for service-to-service traffic" },
    { "vuln_id": "V-285009", "platform": "linux", "check": { "type": "command", "command": "kubectl get authorizationpolicy -n istio-system -o jsonpath='{.items[?(@.spec.action==\"DENY\")].metadata.name}'", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Deny-by-default authorization policies must be configured" },
    { "vuln_id": "V-285010", "platform": "linux", "check": { "type": "command", "command": "kubectl get requestauthentication --all-namespaces --no-headers | wc -l", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "RequestAuthentication resources must be configured for JWT validation" },
    { "vuln_id": "V-285011", "platform": "linux", "check": { "type": "command", "command": "kubectl get deployment istiod -n istio-system -o jsonpath='{.spec.replicas}'", "pattern": "^[2-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Istiod must be deployed with multiple replicas for high availability" },
    { "vuln_id": "V-285012", "platform": "linux", "check": { "type": "command", "command": "kubectl get deployment istiod -n istio-system -o jsonpath='{.spec.template.spec.containers[0].image}'", "pattern": "istio/pilot:\\d+\\.\\d+\\.\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Istiod must run a supported and current version" },
    { "vuln_id": "V-285013", "platform": "linux", "check": { "type": "command", "command": "kubectl get envoyfilter --all-namespaces --no-headers 2>/dev/null | wc -l", "pattern": "^\\d+$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "EnvoyFilter resources must be reviewed and documented" },
    { "vuln_id": "V-285014", "platform": "linux", "check": { "type": "command", "command": "kubectl get sidecar --all-namespaces --no-headers 2>/dev/null | wc -l", "pattern": "^[1-9]\\d*$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Sidecar resources must be configured to limit egress traffic scope" },
    { "vuln_id": "V-285015", "platform": "linux", "check": { "type": "command", "command": "kubectl get configmap istio -n istio-system -o jsonpath='{.data.mesh}' | grep 'outboundTrafficPolicy'", "pattern": "REGISTRY_ONLY", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Outbound traffic policy must be set to REGISTRY_ONLY to block unknown external services" }
  ]
}
