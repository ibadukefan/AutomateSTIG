      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection", "value_name": "DisableRealtimeMonitoring" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Windows Defender real-time protection must be enabled"
    },
    {
      "vuln_id": "V-253261",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection", "value_name": "DisableBehaviorMonitoring" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Windows Defender behavior monitoring must be enabled"
    },
    {
      "vuln_id": "V-253262",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection", "value_name": "DisableOnAccessProtection" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Windows Defender on-access protection must be enabled"
    },
    {
      "vuln_id": "V-253263",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection", "value_name": "DisableScanOnRealtimeEnable" },
