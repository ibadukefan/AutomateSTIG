    },
    {
      "vuln_id": "V-253264",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Policies\\Microsoft\\Windows Defender\\Real-Time Protection", "value_name": "DisableIOAVProtection" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Windows Defender must scan all downloaded files and attachments"
