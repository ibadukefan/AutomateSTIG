{
  "stig_id": "Outlook_2019_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-260600",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "Level" },
      "expected": { "type": "equals", "value": 2 },
      "description": "Outlook 2019 macro security level must be set to high (notifications for signed, disable unsigned)"
    },
    {
      "vuln_id": "V-260601",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "EnableRememberPassword" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Outlook must not allow users to remember passwords for network connections"
    },
    {
      "vuln_id": "V-260602",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "MinEncKey" },
      "expected": { "type": "greater_or_equal", "value": 168 },
      "description": "Outlook 2019 minimum S/MIME encryption key length must be at least 168 bits"
    },
    {
      "vuln_id": "V-260603",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "RequiredSignatureAlgorithm" },
      "expected": { "type": "matches", "pattern": ".+" },
      "description": "Outlook 2019 must have a required S/MIME signature algorithm configured"
    },
    {
      "vuln_id": "V-260604",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "SignAllMessages" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook 2019 must digitally sign all outgoing messages by default"
    },
    {
      "vuln_id": "V-260605",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "EncryptAllMessages" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook 2019 must encrypt all outgoing messages by default"
    },
    {
      "vuln_id": "V-260610",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Options\\Mail", "value_name": "JunkMailImportLists" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Outlook must not import junk mail safe sender lists"
    },
    {
      "vuln_id": "V-260611",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Options\\Mail", "value_name": "JunkMailProtection" },
      "expected": { "type": "greater_or_equal", "value": 2 },
      "description": "Outlook junk mail protection level must be set to high"
    },
    {
      "vuln_id": "V-260612",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Options\\Mail", "value_name": "JunkMailPermanentDelete" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook must permanently delete junk mail instead of moving to Junk folder"
    },
    {
      "vuln_id": "V-260620",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "ShowOLEPackageObj" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Outlook must not display OLE package objects"
    },
    {
      "vuln_id": "V-260621",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Options\\General", "value_name": "ExternalPictures" },
      "expected": { "type": "equals", "value": 0 },
      "description": "Outlook must not automatically download external content in HTML email"
    },
    {
      "vuln_id": "V-260622",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "DontTrustInstalledFiles" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook must not trust installed files for security decisions"
    },
    {
      "vuln_id": "V-260625",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "ForceSTARTTLS" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook must force STARTTLS for SMTP connections"
    },
    {
      "vuln_id": "V-260626",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Security", "value_name": "EnableRPCEncryption" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook must enable RPC encryption"
    },
    {
      "vuln_id": "V-260630",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKCU\\SOFTWARE\\Policies\\Microsoft\\Office\\16.0\\Outlook\\Preferences", "value_name": "EnableLogging" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Outlook must enable mail logging for troubleshooting and audit"
    }
  ]
}
