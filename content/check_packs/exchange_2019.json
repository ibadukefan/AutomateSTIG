    { "vuln_id": "V-259765", "platform": "windows", "check": { "type": "command", "command": "powershell -Command \"Get-AdminAuditLogConfig | Select-Object AdminAuditLogEnabled | Format-List\"", "pattern": "AdminAuditLogEnabled\\s*:\\s*True", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Exchange admin audit logging must be enabled" },
