{
  "stig_id": "AWS_RDS_STIG",
  "platform": "generic",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-281001", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].StorageEncrypted' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS instance storage must be encrypted at rest" },
    { "vuln_id": "V-281002", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].MultiAZ' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS instance must be configured for Multi-AZ deployment" },
    { "vuln_id": "V-281003", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].PubliclyAccessible' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_false" }, "description": "RDS instance must not be publicly accessible" },
    { "vuln_id": "V-281004", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].IAMDatabaseAuthenticationEnabled' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "IAM database authentication must be enabled on the RDS instance" },
    { "vuln_id": "V-281005", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].EnabledCloudwatchLogsExports' --output text", "pattern": "(audit|error|general|slowquery)", "is_regex": true }, "expected": { "type": "is_true" }, "description": "RDS instance must export logs to CloudWatch" },
    { "vuln_id": "V-281006", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].AutoMinorVersionUpgrade' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS instance must have automatic minor version upgrades enabled" },
    { "vuln_id": "V-281007", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].BackupRetentionPeriod' --output text", "pattern": "^([7-9]|[1-9]\\d+)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "RDS backup retention period must be at least 7 days" },
    { "vuln_id": "V-281008", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].DeletionProtection' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS instance must have deletion protection enabled" },
    { "vuln_id": "V-281009", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].CopyTagsToSnapshot' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS instance must copy tags to snapshots" },
    { "vuln_id": "V-281010", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].MonitoringInterval' --output text", "pattern": "^([1-9]|[1-5][0-9]|60)$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Enhanced monitoring must be enabled on the RDS instance" },
    { "vuln_id": "V-281011", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].PerformanceInsightsEnabled' --output text", "pattern": "True", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Performance Insights must be enabled on the RDS instance" },
    { "vuln_id": "V-281012", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].KmsKeyId' --output text", "pattern": "arn:aws:kms:", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS encryption must use a customer-managed KMS key" },
    { "vuln_id": "V-281013", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].DBSubnetGroup.VpcId' --output text", "pattern": "vpc-", "is_regex": false }, "expected": { "type": "is_true" }, "description": "RDS instance must be deployed within a VPC" },
    { "vuln_id": "V-281014", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-db-instances --db-instance-identifier $INSTANCE --query 'DBInstances[0].EngineVersion' --output text", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "RDS instance must run a supported and current engine version" },
    { "vuln_id": "V-281015", "platform": "generic", "check": { "type": "command", "command": "aws rds describe-event-subscriptions --query \"EventSubscriptionsList[?SourceType=='db-instance']\" --output text", "pattern": ".+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "RDS event subscriptions must be configured for instance-level events" }
  ]
}
