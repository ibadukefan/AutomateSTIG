{
  "stig_id": "SharePoint_2019_STIG",
  "platform": "windows",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-260380",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.2\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 1 },
      "description": "SharePoint 2019 must have TLS 1.2 enabled on the server"
    },
    {
      "vuln_id": "V-260381",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\SSL 2.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SSL 2.0 must be disabled on the SharePoint server"
    },
    {
      "vuln_id": "V-260382",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\SSL 3.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "SSL 3.0 must be disabled on the SharePoint server"
    },
    {
      "vuln_id": "V-260383",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.0\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.0 must be disabled on the SharePoint server"
    },
    {
      "vuln_id": "V-260384",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\SecurityProviders\\SCHANNEL\\Protocols\\TLS 1.1\\Server", "value_name": "Enabled" },
      "expected": { "type": "equals", "value": 0 },
      "description": "TLS 1.1 must be disabled on the SharePoint server"
    },
    {
      "vuln_id": "V-260390",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Shared Tools\\Web Server Extensions\\16.0\\WSS", "value_name": "CentralAdministrationPort" },
      "expected": { "type": "matches", "pattern": "\\d+" },
      "description": "SharePoint Central Administration must be configured on a non-standard port"
    },
    {
      "vuln_id": "V-260391",
      "platform": "windows",
      "check": { "type": "audit_policy", "subcategory": "Logon/Logoff", "setting": "Success and Failure" },
      "expected": { "type": "contains", "substring": "Success" },
      "description": "Logon events must be audited on the SharePoint server"
    },
    {
      "vuln_id": "V-260392",
      "platform": "windows",
      "check": { "type": "audit_policy", "subcategory": "Account Logon", "setting": "Success and Failure" },
      "expected": { "type": "contains", "substring": "Success" },
      "description": "Account logon events must be audited on the SharePoint server"
    },
    {
      "vuln_id": "V-260393",
      "platform": "windows",
      "check": { "type": "audit_policy", "subcategory": "Account Management", "setting": "Success and Failure" },
      "expected": { "type": "contains", "substring": "Success" },
      "description": "Account management events must be audited on the SharePoint server"
    },
    {
      "vuln_id": "V-260400",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\Microsoft\\Windows\\CurrentVersion\\Policies\\System", "value_name": "LegalNoticeText" },
      "expected": { "type": "matches", "pattern": ".{10,}" },
      "description": "SharePoint server must display legal notice text before logon"
    },
    {
      "vuln_id": "V-260401",
      "platform": "windows",
      "check": { "type": "security_policy", "section": "System Access", "key": "MinimumPasswordLength" },
      "expected": { "type": "greater_or_equal", "value": 14 },
      "description": "Minimum password length must be at least 14 characters on SharePoint server"
    },
    {
      "vuln_id": "V-260402",
      "platform": "windows",
      "check": { "type": "security_policy", "section": "System Access", "key": "LockoutBadCount" },
      "expected": { "type": "less_or_equal", "value": 3 },
      "description": "Account lockout threshold must be 3 or fewer on SharePoint server"
    },
    {
      "vuln_id": "V-260405",
      "platform": "windows",
      "check": { "type": "service", "name": "SPTimerV4", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "SharePoint Timer Service must be running"
    },
    {
      "vuln_id": "V-260406",
      "platform": "windows",
      "check": { "type": "service", "name": "SPAdminV4", "expected_status": "running" },
      "expected": { "type": "is_true" },
      "description": "SharePoint Administration Service must be running"
    },
    {
      "vuln_id": "V-260410",
      "platform": "windows",
      "check": { "type": "registry", "path": "HKLM\\SYSTEM\\CurrentControlSet\\Control\\Lsa", "value_name": "LmCompatibilityLevel" },
      "expected": { "type": "equals", "value": 5 },
      "description": "SharePoint server must use NTLMv2 only for LAN Manager authentication"
    }
  ]
}
