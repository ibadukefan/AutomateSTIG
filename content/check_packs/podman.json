{
  "stig_id": "Podman_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    { "vuln_id": "V-286001", "platform": "linux", "check": { "type": "command", "command": "podman info --format '{{.Host.Security.Rootless}}'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "Podman must be configured to run in rootless mode" },
    { "vuln_id": "V-286002", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "seccomp_profile\\s*=\\s*\".*\\.json\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Podman must use a seccomp profile for containers" },
    { "vuln_id": "V-286003", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "default_capabilities\\s*=\\s*\\[", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Default container capabilities must be explicitly defined" },
    { "vuln_id": "V-286004", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "no_new_privileges\\s*=\\s*true", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Containers must not be allowed to gain new privileges" },
    { "vuln_id": "V-286005", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "log_driver\\s*=\\s*\"(journald|k8s-file|json-file)\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Podman must be configured with a centralized logging driver" },
    { "vuln_id": "V-286006", "platform": "linux", "check": { "type": "command", "command": "podman ps --all --format '{{.Status}}' | grep -ci 'privileged'", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "No containers must be running in privileged mode" },
    { "vuln_id": "V-286007", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "userns\\s*=\\s*\"auto\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "User namespace isolation must be enabled by default" },
    { "vuln_id": "V-286008", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "netns\\s*=\\s*\"(private|slirp4netns)\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Container network namespace must be private" },
    { "vuln_id": "V-286009", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "pidns\\s*=\\s*\"private\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Container PID namespace must be private" },
    { "vuln_id": "V-286010", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "ipcns\\s*=\\s*\"private\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Container IPC namespace must be private" },
    { "vuln_id": "V-286011", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/containers.conf", "pattern": "read_only\\s*=\\s*true", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Container root filesystem must be read-only by default" },
    { "vuln_id": "V-286012", "platform": "linux", "check": { "type": "command", "command": "podman info --format '{{.Host.Security.SELinuxEnabled}}'", "pattern": "true", "is_regex": false }, "expected": { "type": "is_true" }, "description": "SELinux must be enabled for Podman container isolation" },
    { "vuln_id": "V-286013", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/registries.conf", "pattern": "unqualified-search-registries\\s*=\\s*\\[", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Unqualified search registries must be explicitly configured" },
    { "vuln_id": "V-286014", "platform": "linux", "check": { "type": "file_content", "path": "/etc/containers/policy.json", "pattern": "\"type\":\\s*\"(signedBy|sigstoreSigned)\"", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Container image signature verification must be configured" },
    { "vuln_id": "V-286015", "platform": "linux", "check": { "type": "command", "command": "podman version --format '{{.Client.Version}}'", "pattern": "\\d+\\.\\d+\\.\\d+", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Podman must run a supported and current version" }
  ]
}
