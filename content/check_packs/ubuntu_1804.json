    { "vuln_id": "V-219191", "platform": "linux", "check": { "type": "service", "name": "auditd", "expected_status": "running" }, "expected": { "type": "is_true" }, "description": "Audit daemon must be running" },
    { "vuln_id": "V-219200", "platform": "linux", "check": { "type": "file_content", "path": "/etc/login.defs", "pattern": "PASS_MAX_DAYS\\s+60", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Maximum password age must be 60 days or less" }
  ]
