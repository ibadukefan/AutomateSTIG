    { "vuln_id": "V-219148", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "PermitEmptyPasswords\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must not allow empty passwords" },
    { "vuln_id": "V-219149", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveInterval\\s+[1-9]", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveInterval must be set" },
    { "vuln_id": "V-219150", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "ClientAliveCountMax\\s+[01]$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH ClientAliveCountMax must be 1 or less" },
    { "vuln_id": "V-219151", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "Banner\\s+/etc/issue", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must display a login banner" },
    { "vuln_id": "V-219152", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "X11Forwarding\\s+no", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH X11 forwarding must be disabled" },
    { "vuln_id": "V-219153", "platform": "linux", "check": { "type": "file_content", "path": "/etc/ssh/sshd_config", "pattern": "UsePAM\\s+yes", "is_regex": true }, "expected": { "type": "is_true" }, "description": "SSH must use PAM" },
    { "vuln_id": "V-219160", "platform": "linux", "check": { "type": "sysctl", "key": "net.ipv4.ip_forward" }, "expected": { "type": "equals", "value": "0" }, "description": "IP forwarding must be disabled" },
