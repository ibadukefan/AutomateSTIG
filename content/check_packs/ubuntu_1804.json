    { "vuln_id": "V-219170", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/shadow", "owner": "root", "group": "shadow", "mode": "0640" }, "expected": { "type": "is_true" }, "description": "/etc/shadow must be mode 0640, owned by root:shadow" },
    { "vuln_id": "V-219171", "platform": "linux", "check": { "type": "file_permission", "path": "/etc/passwd", "owner": "root", "group": null, "mode": "0644" }, "expected": { "type": "is_true" }, "description": "/etc/passwd must be mode 0644 and owned by root" },
