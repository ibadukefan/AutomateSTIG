      "check": { "type": "registry", "path": "HKLM\\SOFTWARE\\WOW6432Node\\Tanium\\Tanium Server", "value_name": "FIPS" },
      "expected": { "type": "equals", "value": 1 },
      "description": "Tanium Server must enable FIPS mode"
    },
    {
      "vuln_id": "V-260002",
