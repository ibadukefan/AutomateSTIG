{
  "checks": [
    {
      "check": {
        "command": "powershell -NoProfile -Command \"$os=Get-CimInstance Win32_OperatingSystem; if ($os.Caption -eq 'Microsoft Windows 11 Enterprise' -and $os.OSArchitecture -like '64-bit*') { 'Compliant' }\"",
        "type": "command_output"
      },
      "description": "Domain-joined systems must use Windows 11 Enterprise Edition 64-bit version.",
      "expected": {
        "type": "equals",
        "value": "Compliant"
      },
      "platform": "windows",
      "vuln_id": "V-253254"
    },
    {
      "check": {
        "key": "LockoutDuration",
        "section": "System Access",
        "type": "security_policy"
      },
      "description": "Windows 11 account lockout duration must be configured to 15 minutes or greater.",
      "expected": {
        "type": "greater_or_equal",
        "value": 15
      },
      "platform": "windows",
      "vuln_id": "V-253297"
    },
    {
      "check": {
        "key": "MinimumPasswordAge",
        "section": "System Access",
        "type": "security_policy"
      },
      "description": "The minimum password age must be configured to at least 1 day.",
      "expected": {
        "type": "greater_or_equal",
        "value": 1
      },
      "platform": "windows",
      "vuln_id": "V-253302"
    },
    {
      "check": {
        "key": "SeNetworkLogonRight",
        "section": "Privilege Rights",
        "type": "security_policy"
      },
      "description": "The \"Access this computer from the network\" user right must only be assigned to the Administrators and Remote Desktop Users groups.",
      "expected": {
        "type": "equals",
        "value": "*S-1-5-32-544,*S-1-5-32-555"
      },
      "platform": "windows",
      "vuln_id": "V-253480"
    },
    {
      "check": {
        "path": "HKLM\\Software\\Policies\\Microsoft\\Internet Explorer\\Main",
        "type": "registry",
        "value_name": "NotifyDisableIEOptions"
      },
      "description": "Internet Explorer must be disabled for Windows 11.",
      "expected": {
        "type": "equals",
        "value": 0
      },
      "platform": "windows",
      "vuln_id": "V-256893"
    }
  ],
  "platform": "windows",
  "stig_id": "scap_mil.disa.stig_collection_U_MS_Windows_11_V2R4_STIG_SCAP_1-3_Benchmark",
