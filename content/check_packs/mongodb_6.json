    {
      "vuln_id": "V-252151",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "enableEncryption:\\s*true", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MongoDB 6 must enable encryption at rest"
