      "description": "MongoDB 6 must audit authorization successes"
    },
    {
      "vuln_id": "V-252150",
      "platform": "linux",
      "check": { "type": "command", "command": "mongosh --quiet --eval \"db.system.users.find({credentials: {\\\"SCRAM-SHA-1\\\": {\\$exists: true}}}).count()\" --tls", "pattern": "^0$", "is_regex": true },
      "expected": { "type": "is_true" },
