      "description": "MongoDB 6 must have the auditLog section configured in mongod.conf"
    },
    {
      "vuln_id": "V-252142",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "format:\\s*(JSON|BSON)", "is_regex": true },
