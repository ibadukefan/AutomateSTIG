      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "CAFile:\\s*\\S+", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MongoDB 6 must have a TLS CA file configured for certificate validation"
    },
    {
      "vuln_id": "V-252139",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "disabledProtocols:\\s*TLS1_0,TLS1_1", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MongoDB 6 must disable TLS 1.0 and TLS 1.1 protocols"
    },
    {
      "vuln_id": "V-252140",
      "platform": "linux",
