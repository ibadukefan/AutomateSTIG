{
  "stig_id": "MongoDB_6_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-252134",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "authorization:\\s*enabled", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MongoDB 6 must have authorization enabled in mongod.conf"
    },
    {
      "vuln_id": "V-252135",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "security:", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "MongoDB 6 must have the security section configured in mongod.conf"
    },
    {
      "vuln_id": "V-252136",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "mode:\\s*requireTLS", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "MongoDB 6 must require TLS for all network connections (net.tls.mode: requireTLS)"
    },
    {
      "vuln_id": "V-252137",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/mongod.conf", "pattern": "certificateKeyFile:\\s*\\S+", "is_regex": true },
