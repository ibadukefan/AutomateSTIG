    {
      "vuln_id": "V-242400",
      "platform": "linux",
      "check": {
        "type": "all",
        "checks": [
          { "type": "file_content", "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--anonymous-auth=false", "is_regex": false },
          { "type": "file_content", "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--authorization-mode=.*RBAC", "is_regex": true },
          { "type": "file_content", "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--audit-log-path=", "is_regex": false }
        ]
