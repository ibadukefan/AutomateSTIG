{
  "stig_id": "Kubernetes_STIG",
  "platform": "linux",
  "version": "1.0.0",
  "checks": [
    {
      "vuln_id": "V-242376",
      "platform": "linux",
      "check": { "type": "command", "command": "kubectl get clusterrolebinding -o jsonpath='{.items[?(@.subjects[0].name==\"system:anonymous\")].metadata.name}'", "pattern": ".+", "is_regex": true },
      "expected": { "type": "is_false" },
      "description": "Anonymous authentication must not have any cluster role bindings"
    },
    {
      "vuln_id": "V-242377",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--anonymous-auth=false", "is_regex": false },
      "expected": { "type": "is_true" },
      "description": "Kubernetes API server must have anonymous authentication disabled"
    },
    {
      "vuln_id": "V-242378",
      "platform": "linux",
      "check": { "type": "file_content", "path": "/etc/kubernetes/manifests/kube-apiserver.yaml", "pattern": "--authorization-mode=.*RBAC", "is_regex": true },
      "expected": { "type": "is_true" },
      "description": "Kubernetes API server must use RBAC authorization mode"
    },
    {
      "vuln_id": "V-242379",
      "platform": "linux",
