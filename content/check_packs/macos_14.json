    { "vuln_id": "V-259539", "platform": "generic", "check": { "type": "command", "command": "system_profiler SPFirewallDataType | grep 'Stealth Mode'", "pattern": "Stealth Mode:\\s+enabled", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Firewall stealth mode must be enabled" },
