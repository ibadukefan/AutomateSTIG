    { "vuln_id": "V-259530", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.loginwindow GuestEnabled", "pattern": "^0$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Guest account must be disabled" },
    { "vuln_id": "V-259531", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.loginwindow LoginwindowText 2>&1", "pattern": ".{10,}", "is_regex": true }, "expected": { "type": "is_true" }, "description": "A login window banner must be displayed" },
