    { "vuln_id": "V-259541", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.mDNSResponder NoMulticastAdvertisements 2>&1", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Bonjour multicast advertising must be disabled" },
    { "vuln_id": "V-259542", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.MCX DisableGuestAccount 2>&1", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "MCX guest account must be disabled" },
    { "vuln_id": "V-259543", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.alf stealthenabled", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Application firewall stealth mode must be enabled via alf" },
    { "vuln_id": "V-259544", "platform": "generic", "check": { "type": "command", "command": "defaults read /Library/Preferences/com.apple.TimeMachine AutoBackup 2>&1", "pattern": "^1$", "is_regex": true }, "expected": { "type": "is_true" }, "description": "Time Machine automatic backups must be enabled" }
