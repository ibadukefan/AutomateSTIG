{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AutomateSTIG Coverage Manifest",
  "type": "object",
  "required": ["stig_id", "version", "source", "status", "total_rules", "rules"],
  "additionalProperties": false,
  "properties": {
    "stig_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "source": { "type": "string", "minLength": 1 },
    "status": { "enum": ["experimental", "supported", "production"] },
    "total_rules": { "type": "integer", "minimum": 0 },
    "generated_from": { "type": "string" },
    "generated_at": { "type": "string" },
    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["vuln_id", "rule_id", "classification", "reason"],
        "additionalProperties": false,
        "properties": {
          "vuln_id": { "type": "string", "minLength": 1 },
          "rule_id": { "type": "string", "minLength": 1 },
          "title": { "type": "string" },
          "severity": { "type": "string" },
          "classification": {
            "enum": ["automated", "scanner_import", "manual", "not_applicable", "unsupported"]
          },
          "check_pack": { "type": "string" },
          "check_id": { "type": "string" },
          "evidence_required": { "type": "boolean", "default": true },
          "reason": { "type": "string", "minLength": 1 },
          "tracking_issue": { "type": "string" },
          "validated_by": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "allOf": [
          {
            "if": { "properties": { "classification": { "const": "automated" } } },
            "then": { "required": ["check_pack", "check_id"] }
          }
        ]
      }
    }
  }
}
